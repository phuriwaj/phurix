---
/**
 * Accordion — used on FAQ sections.
 * 300ms duration, ease-out-soft curve.
 * Plain details/summary implementation (no JS needed).
 */
interface Props {
  items: Array<{ q: string; a: string }>;
}

const { items } = Astro.props;
---

<div class="accordion-phx">
  {items.map((item) => (
    <details class="accordion-item">
      <summary class="accordion-summary">
        <span>{item.q}</span>
        <span class="accordion-chev" aria-hidden="true">+</span>
      </summary>
      <div class="accordion-answer">
        <p>{item.a}</p>
      </div>
    </details>
  ))}
</div>

<style>
  .accordion-phx {
    border-top: 1px solid var(--color-hairline);
  }

  .accordion-item {
    border-bottom: 1px solid var(--color-hairline);
  }

  .accordion-summary {
    list-style: none;
    cursor: pointer;
    padding: var(--spacing-5) 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-5);
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: var(--tracking-display-tight);
  }

  .accordion-summary::-webkit-details-marker { display: none; }

  .accordion-chev {
    font-size: 1.6rem;
    color: var(--color-action-blue);
    transition: transform var(--duration-expander) var(--ease-out-soft);
  }

  .accordion-item[open] .accordion-chev {
    transform: rotate(45deg);
  }

  .accordion-answer {
    padding: 0 0 var(--spacing-7);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--text-body);
    line-height: 1.5;
    max-width: 70ch;
  }
</style>
