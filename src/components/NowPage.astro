---
/**
 * NowPage — short section wrapper for /now page.
 * A Maggie-pattern /now page is concise: location, work, reading, etc.
 * This wraps the content sections with consistent styling.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<section class:list={['now-section', className]}>
  <slot />
</section>

<style>
  .now-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }
</style>
