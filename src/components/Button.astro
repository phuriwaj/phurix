---
/**
 * Pill Button — full radius, near-black or on-dark surfaces.
 *
 * Variants (mapped 1:1 to Cohere-inspired DESIGN.md §4):
 *   primary          — near-black fill, white text
 *   outline          — transparent, near-black text + border
 *   announcement     — near-black filled, white text (small uppercase strip)
 *   on-dark          — white fill, near-black text (primary CTA on dark band)
 *   on-dark-outline  — transparent, white border, white text
 *
 * Sizes:
 *   sm — 12px / 16px padding, 14px label
 *   md — 12px / 24px padding, 14px label
 *   lg — 14px / 32px padding, 16px label
 *
 * Active state: color/background only (no scale transform).
 */
type Variant =
  | 'primary'
  | 'outline'
  | 'announcement'
  | 'on-dark'
  | 'on-dark-outline';

interface Props {
  variant?: Variant;
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  ariaLabel?: string;
  /** Optional icon glyph (e.g. "★") shown left of label. */
  icon?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className = '',
  ariaLabel,
  icon,
} = Astro.props;

const Tag = href ? 'a' : 'button';
const classes = [
  'btn',
  `btn-${variant}`,
  `btn-${size}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag
  href={href}
  type={!href ? type : undefined}
  class={classes}
  aria-label={ariaLabel}
>
  {icon && <span class="btn-icon" aria-hidden="true">{icon}</span>}
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-1);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-button);
    line-height: 1.2;
    letter-spacing: var(--tracking-tight);
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    cursor: pointer;
    user-select: none;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background-color var(--duration-button) ease,
      color var(--duration-button) ease,
      border-color var(--duration-button) ease,
      box-shadow var(--duration-button) ease;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* --- Sizes ------------------------------------------------------ */
  .btn-sm {
    padding: 7px 16px;
    font-size: 1.4rem;
  }
  .btn-md {
    padding: 12px 24px;
    font-size: 1.4rem;
  }
  .btn-lg {
    padding: 14px 32px;
    font-size: var(--text-body);
  }

  /* --- Variant: primary (near-black filled, white text) ----------- */
  .btn-primary {
    background: var(--color-near-black);
    color: var(--color-on-dark);
    border-color: var(--color-near-black);
  }
  .btn-primary:hover:not(:disabled) {
    background: var(--color-cohere-black);
    border-color: var(--color-cohere-black);
  }

  /* --- Variant: outline (near-black outline, transparent fill) --- */
  .btn-outline {
    background: transparent;
    color: var(--color-near-black);
    border-color: var(--color-near-black);
  }
  .btn-outline:hover:not(:disabled) {
    background: var(--color-near-black);
    color: var(--color-on-dark);
  }

  /* --- Variant: announcement (small uppercase black strip) ------- */
  .btn-announcement {
    background: var(--color-cohere-black);
    color: var(--color-on-dark);
    border-color: var(--color-cohere-black);
    text-transform: uppercase;
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono);
  }
  .btn-announcement:hover:not(:disabled) {
    background: var(--color-near-black);
  }

  /* --- Variant: on-dark (white fill, near-black text) ------------ */
  .btn-on-dark {
    background: var(--color-on-dark);
    color: var(--color-near-black);
    border-color: var(--color-on-dark);
  }
  .btn-on-dark:hover:not(:disabled) {
    background: var(--color-soft-stone);
    border-color: var(--color-soft-stone);
  }

  /* --- Variant: on-dark-outline (transparent, white border) ------ */
  .btn-on-dark-outline {
    background: transparent;
    color: var(--color-on-dark);
    border-color: var(--color-on-dark);
  }
  .btn-on-dark-outline:hover:not(:disabled) {
    background: var(--color-on-dark);
    color: var(--color-near-black);
  }

  /* --- Icon gutter ----------------------------------------------- */
  .btn-icon {
    font-size: 1em;
    line-height: 1;
  }
</style>
