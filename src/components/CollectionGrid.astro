---
/**
 * CollectionGrid — responsive grid container for garden/card collections.
 * 1 col mobile → 2 col tablet → 3 col desktop.
 * Optional `tone` prop tints the grid background for a wash effect.
 */
interface Props {
  cols?: 1 | 2 | 3;
  gap?: 'sm' | 'md' | 'lg';
  /** Optional background tone for the grid container. */
  tone?: 'none' | 'pale-green' | 'pale-blue';
  class?: string;
}

const { cols = 3, gap = 'md', tone = 'none', class: className = '' } = Astro.props;
---

<div class:list={['collection-grid', `cols-${cols}`, `gap-${gap}`, `tone-${tone}`, className]}>
  <slot />
</div>

<style>
  .collection-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .gap-sm { gap: var(--spacing-7); }
  .gap-md { gap: var(--spacing-10); }
  .gap-lg { gap: var(--spacing-12); }

  .tone-none { background: transparent; }
  .tone-pale-green {
    background: var(--color-pale-green-wash);
    padding: var(--spacing-10);
    border-radius: var(--radius-md);
  }
  .tone-pale-blue {
    background: var(--color-pale-blue-wash);
    padding: var(--spacing-10);
    border-radius: var(--radius-md);
  }

  @media (min-width: 768px) {
    .cols-2,
    .cols-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .cols-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
