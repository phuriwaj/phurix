---
/**
 * TopicChip — pill chip for topic tags and filters.
 * Mono uppercase outline, coral color, active inverts to coral fill.
 * Cite as: DESIGN.md §7 (blog-filter-chip).
 */
interface Props {
  label: string;
  active?: boolean;
  href?: string;
  /** Visual size. sm (12px), md (14px default), lg (18px). */
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { label, active = false, href, size = 'md', class: className = '' } = Astro.props;

const Tag = href ? 'a' : 'span';
---

<Tag
  href={href}
  class:list={['topic-chip', `topic-chip-${size}`, active && 'topic-chip-active', className]}
>
  {label}
</Tag>

<style>
  .topic-chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 400;
    text-transform: uppercase;
    background: transparent;
    color: var(--color-coral-text);
    border: 1px solid var(--color-coral);
    text-decoration: none;
    cursor: pointer;
    line-height: 1.5;
    transition:
      background-color var(--duration-button) ease,
      color var(--duration-button) ease,
      border-color var(--duration-button) ease;
  }

  .topic-chip-sm {
    font-size: 1.2rem;
    letter-spacing: var(--tracking-mono);
    padding: var(--spacing-1) var(--spacing-4);
    border-radius: var(--radius-pill);
  }

  .topic-chip-md {
    font-size: 1.4rem;
    letter-spacing: var(--tracking-mono);
    padding: var(--spacing-2) var(--spacing-4);
    border-radius: var(--radius-pill);
  }

  .topic-chip-lg {
    font-size: 1.8rem;
    letter-spacing: var(--tracking-mono);
    padding: var(--spacing-4) var(--spacing-7);
    border-radius: var(--radius-xl);
  }

  .topic-chip:hover:not(.topic-chip-active) {
    background: color-mix(in srgb, var(--color-coral) 8%, var(--color-canvas));
  }

  .topic-chip-active {
    background: var(--color-coral);
    color: var(--color-cohere-black);
    border-color: var(--color-coral);
  }

  .topic-chip-active:hover {
    background: var(--color-soft-coral);
    border-color: var(--color-soft-coral);
  }
</style>
