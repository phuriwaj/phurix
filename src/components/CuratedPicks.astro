---
/**
 * CuratedPicks — curated picks block.
 * Renders an <ol> where each item is "✦ <a href=...>{title}</a>"
 * separated by hairline <hr>s. Used on / and /essays.
 * Cite as: DESIGN.md §7 (Component — curated picks block).
 */
import CuratedMark from './CuratedMark.astro';

interface Props {
  /** Each entry: a title + href. The ✦ mark is added automatically. */
  items: Array<{ title: string; href: string }>;
  /** Optional heading shown above the block. Default: no heading. */
  heading?: string;
  class?: string;
}

const { items, heading, class: className = '' } = Astro.props;
---

<div class:list={['curated-picks', className]}>
  {heading && <p class="curated-picks-heading">{heading}</p>}
  <ol class="curated-picks-list">
    {items.map((item) => (
      <li class="curated-picks-item">
        <CuratedMark size="md" />
        <a href={item.href} class="curated-picks-link">{item.title}</a>
      </li>
    ))}
  </ol>
</div>

<style>
  .curated-picks {
    width: 100%;
  }

  .curated-picks-heading {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral);
    margin-bottom: var(--spacing-5);
  }

  .curated-picks-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 60ch;
  }

  .curated-picks-item {
    display: flex;
    align-items: baseline;
    padding-block: var(--spacing-5);
    border-top: 1px solid var(--color-hairline);
  }

  .curated-picks-item:last-child {
    border-bottom: 1px solid var(--color-hairline);
  }

  .curated-picks-link {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-body-lg);
    font-weight: 400;
    color: var(--color-action-blue);
    text-decoration: none;
    letter-spacing: var(--tracking-display-tight);
    transition: color var(--duration-button) ease;
  }

  .curated-picks-link:hover {
    color: var(--color-cohere-black);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 2px;
  }
</style>
