---
/**
 * Feature Band — full-width dark hero strip.
 * 60/40 split on desktop, stacked on mobile.
 * On-dark text throughout; secondary copy in --color-on-dark-muted.
 * Cite as: DESIGN.md §7 (dark-feature-band).
 */
import Button from '@/components/Button.astro';

interface Props {
  headline: string;
  subhead?: string;
  /** Optional right-column image (product photo, illustration). */
  imageSrc?: string;
  imageAlt?: string;
  /** CTA pairing: primary (white fill) + secondary (white outline). */
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  /** Dark surface tone. 'deep-green' (default) or 'dark-navy'. */
  tone?: 'deep-green' | 'dark-navy';
}

const {
  headline,
  subhead,
  imageSrc,
  imageAlt = '',
  primaryCta,
  secondaryCta,
  tone = 'deep-green',
} = Astro.props;
---

<section class:list={['band-phx', `band-${tone}`]}>
  <div class="band-inner">
    <div class="band-content">
      <h2 class="band-headline">{headline}</h2>
      {subhead && <p class="band-subhead">{subhead}</p>}
      {(primaryCta || secondaryCta) && (
        <div class="band-actions">
          {primaryCta && (
            <Button variant="on-dark" href={primaryCta.href}>
              {primaryCta.label}
            </Button>
          )}
          {secondaryCta && (
            <Button variant="on-dark-outline" href={secondaryCta.href}>
              {secondaryCta.label}
            </Button>
          )}
        </div>
      )}
    </div>
    {imageSrc && (
      <div class="band-media">
        <img src={imageSrc} alt={imageAlt} loading="lazy" />
      </div>
    )}
  </div>
</section>

<style>
  .band-phx {
    color: var(--color-on-dark);
  }

  .band-deep-green {
    background: var(--color-deep-green);
  }

  .band-dark-navy {
    background: var(--color-dark-navy);
  }

  .band-inner {
    max-width: var(--container-xl);
    margin-inline: auto;
    padding: var(--spacing-15) var(--spacing-gutter);
    display: grid;
    gap: var(--spacing-12);
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .band-inner {
      grid-template-columns: 60% 40%;
      padding: var(--spacing-17) var(--spacing-gutter-lg);
    }
  }

  .band-headline {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 6vw, 6rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: var(--tracking-display-tight);
    color: var(--color-on-dark);
    margin: 0 0 var(--spacing-7);
    max-width: 18ch;
  }

  .band-subhead {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--color-on-dark-muted);
    margin-bottom: var(--spacing-8);
    max-width: 50ch;
  }

  .band-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-5);
  }

  .band-media {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
  }

  .band-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 1024px) {
    .band-media { aspect-ratio: 1; }
  }
</style>
