---
/**
 * Footer — three-cluster near-black band.
 *   Cluster 1 — Subscribe (newsletter form, coral mono eyebrow)
 *   Cluster 2 — Find more (inline links + blogroll <details>)
 *   Cluster 3 — Social + brand (icons + copyright)
 * Cite as: DESIGN.md §8 (footer), §9 (subscribe), §10 (blogroll).
 */
import { blogroll } from '@/data/blogroll';

const socialLinks = [
  {
