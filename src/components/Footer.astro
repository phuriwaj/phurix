  },
  {
    label: 'RSS',
    href: '/rss.xml',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg>`,
  },
];

const year = new Date().getFullYear();
---

<footer class="footer-phx">
  <div class="container-phx footer-inner">
    <div class="footer-social">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          class="footer-social-link"
          aria-label={link.label}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          <span class="footer-icon" set:html={link.icon} />
        </a>
      ))}
    </div>

    <div class="footer-bottom">
      <small class="footer-copy">© {year} Phuriwaj Ruengnaowaroj</small>
      <small class="footer-tagline">Built with care</small>
    </div>
  </div>
</footer>

<style>
  .footer-phx {
    margin-top: var(--spacing-7);
    background: var(--color-house-green);
    color: var(--color-text-white);
    padding-block: var(--spacing-5);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-4);
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
  }

  .footer-social-link {
    color: var(--color-text-white-soft);
    transition: color var(--duration-button) ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-social-link:hover {
    color: var(--color-text-white);
  }

  .footer-icon {
    display: block;
    width: 20px;
    height: 20px;
  }

  .footer-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-copy,
  .footer-tagline {
    font-size: var(--text-micro);
    color: var(--color-text-white-soft);
  }
</style>
