---
/**
 * Global Navigation — fixed top bar.
 * Progressive height: 64 (xs) → 72 (sm) → 83 (md) → 99 (lg).
 * Shadow stack: three-layer soft lift.
 *
 * Maggie-style: wordmark left, simple text-link nav right, hamburger mobile.
 * No Sign in/Join now pills.
 *
 * Cite as: DESIGN.md §8 (nav) — 7-item list (Home / Garden / Essays / Notes
 * / Patterns / Now / Random) with mobile hamburger disclosure.
 */
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/garden', label: 'Garden' },
  { href: '/essays', label: 'Essays' },
  { href: '/notes', label: 'Notes' },
  { href: '/patterns', label: 'Patterns' },
  { href: '/now', label: 'Now' },
  { href: '/random', label: 'Random' },
];

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  if (href === '/random') return false; // redirect endpoint, never active
  if (href === '/now') return pathname === '/now';
  return pathname === href || pathname.startsWith(href + '/');
};
---

<header class="nav-phx">
  <div class="nav-inner">
    {/* Wordmark */}
    <a href="/" class="nav-wordmark" aria-label="phurix home">
      <span class="nav-wordmark-text">phurix</span>
    </a>

    {/* Hamburger — mobile only */}
    <button
      type="button"
      class="nav-toggle"
      aria-label="Toggle navigation"
      aria-controls="nav-mobile-menu"
      aria-expanded="false"
      data-nav-toggle
    >
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
    </button>

    {/* Primary links (desktop) */}
    <nav class="nav-links" aria-label="Primary">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'nav-link',
            isActive(link.href) && 'nav-link-active',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  {/* Mobile menu — appears below the bar when hamburger is open */}
  <nav
    id="nav-mobile-menu"
    class="nav-mobile"
    aria-label="Primary mobile"
    data-nav-mobile
    hidden
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'nav-mobile-link',
          isActive(link.href) && 'nav-link-active',
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .nav-phx {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    background: var(--color-white);
    box-shadow: var(--shadow-nav);
    height: var(--nav-h-xs);
  }

  @media (min-width: 480px) {
    .nav-phx { height: var(--nav-h-sm); }
  }
  @media (min-width: 768px) {
    .nav-phx { height: var(--nav-h-md); }
  }
  @media (min-width: 1024px) {
    .nav-phx { height: var(--nav-h-lg); }
  }

  .nav-inner {
    height: 100%;
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--spacing-gutter);
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
  }

  .nav-wordmark-text {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.8rem;
    letter-spacing: var(--tracking-display);
    color: var(--color-starbucks-green);
  }

  /* Hamburger — visible <768px only */
  .nav-toggle {
    display: inline-flex;
    margin-left: auto;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
    width: 40px;
    height: 40px;
    border-radius: 4px;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .nav-toggle { display: none; }
  }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text-black);
    border-radius: 1px;
    transition: transform var(--duration-button) ease, opacity var(--duration-button) ease;
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Desktop nav links — hidden <768px, visible ≥768px */
  .nav-links {
    display: none;
    margin-left: auto;
    gap: var(--spacing-5);
  }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-black);
    padding-block: var(--spacing-1);
    transition: color var(--duration-button) ease;
    text-decoration: none;
    position: relative;
  }

  .nav-link:hover { color: var(--color-starbucks-green); }

  .nav-link-active {
    color: var(--color-starbucks-green);
  }

  .nav-link-active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-starbucks-green);
    border-radius: 1px;
  }

  /* Mobile menu — hidden ≥768px; toggles open below the bar <768px */
  .nav-mobile {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--color-white);
    border-top: 1px solid var(--color-hairline);
    padding: var(--spacing-2) var(--spacing-gutter) var(--spacing-3);
  }

  .nav-mobile[hidden] { display: none; }

  @media (min-width: 768px) {
    .nav-mobile { display: none !important; }
  }

  .nav-mobile-link {
    display: block;
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-text-black);
    padding-block: var(--spacing-3);
    text-decoration: none;
    border-bottom: 1px solid var(--color-hairline);
  }

  .nav-mobile-link:last-child {
    border-bottom: none;
  }

  .nav-mobile-link:hover { color: var(--color-starbucks-green); }
</style>

<script>
  function initNavToggle() {
    const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    const menu = document.querySelector<HTMLElement>('[data-nav-mobile]');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      if (isOpen) {
        menu.setAttribute('hidden', '');
      } else {
        menu.removeAttribute('hidden');
      }
    });
  }

  initNavToggle();
  document.addEventListener('astro:after-swap', initNavToggle);
</script>
