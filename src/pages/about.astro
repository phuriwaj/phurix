---
/**
 * /about — portrait of the author.
 * Cite as: DESIGN.md §4 (subscribe surface), §8 (chrome), §9 (about page).
 *
 * Sections (top to bottom):
 *   1. Page header
 *   2. Identity (long-form prose + portrait photo)
 *   3. Subscribe band (single, dark-green)
 *   4. Now preview (top 3 items from /now)
 *   5. Work history (Timeline)
 *   6. Projects — recent 2
 *   7. Talks — recent 3
 *   8. Skills chip row
 *   9. Closing CTA row
 */
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';
import Timeline from '@/components/Timeline.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import NewsletterBand from '@/components/NewsletterBand.astro';
import GardenCard from '@/components/GardenCard.astro';
import CollectionGrid from '@/components/CollectionGrid.astro';
import { getCollection } from 'astro:content';
import { nowItems } from '@/data/now';

const workHistory = [
  {
    role: 'Senior Frontend Engineer',
    org: 'Clearhead',
    dates: '2022–Present',
    description: 'Building design systems and React component libraries for a remote-first product team.',
  },
  {
    role: 'Frontend Developer',
    org: 'Freelance',
    dates: '2019–2022',
    description: 'Worked with early-stage startups on landing pages, dashboards, and design system audits.',
  },
  {
    role: 'UI Designer',
    org: 'Studio Nitro',
    dates: '2017–2019',
    description: 'Designed interfaces for mobile apps and web products, collaborating closely with engineering.',
  },
  {
    role: 'Junior Designer',
    org: 'Agency RKT',
    dates: '2015–2017',
    description: 'Production design for marketing sites and branding projects.',
  },
];

const skills = [
  'TypeScript', 'React', 'Astro', 'CSS / Tailwind', 'Node.js', 'PostgreSQL', 'Figma', 'Design Systems',
];

// Now preview — top three items from the shared data source.
// Filter to entries that carry a `value` string (the data file also has
// `list` entries; those render as bullet lists on /now and aren't suited
// to the inline preview on /about).
const nowPreview = nowItems
  .filter((item): item is { label: string; value: string } => 'value' in item)
  .slice(0, 3);

// Projects — 2 most-recent by year desc (or by title if year missing).
const allProjects = await getCollection('projects');
const projects = allProjects
  .slice()
  .sort((a, b) => {
    const ay = a.data.year ?? 0;
    const by = b.data.year ?? 0;
    return by - ay;
  })
  .slice(0, 2);

// Talks — 3 most-recent by date desc.
const allTalks = await getCollection('talks');
const talks = allTalks
  .slice()
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout
  title="About — phurix"
  description="About Phuriwaj, web developer and designer based in Bangkok."
>
  {/* ---- 1. Page header ------------------------------------------------ */}
  <section class="page-header-section">
    <div class="container-phx">
      <p class="section-eyebrow">About</p>
      <h1 class="page-title">Phuriwaj Ruengnaowaroj</h1>
      <p class="page-lede">
        I'm a web developer and designer based in Bangkok, building
        thoughtful interfaces and the systems that hold them together.
      </p>
    </div>
  </section>

  {/* ---- 2. Identity (long-form prose + portrait) --------------------- */}
  <section class="container-phx section">
    <div class="identity-grid">
      <div class="identity-photo">
        <TopicPhoto topic="anthropology" scale="portrait" showCredit={true} />
      </div>
      <div class="prose identity-prose">
        {/* TODO: author can revise the identity prose. */}
        <p>
          I'm a web developer and designer based in Bangkok, working at
          the intersection of design systems and the everyday interfaces
          that depend on them. I spend most of my time thinking about
          components — what makes them feel coherent, what makes them
          survive contact with real product work, and what makes them
          cheap to change.
        </p>
        <p>
          Before this I worked as a UI designer at small studios, then
          as a freelance frontend developer for early-stage startups. The
          throughline has always been the same: I want the software I
          ship to feel considered. Not polished for the sake of polish,
          but deliberate in the small decisions — typography, spacing,
          motion, the way a button looks when you press it.
        </p>
        <p>
          Outside of work I keep a small digital garden, read more than I
          probably should, and drink a lot of coffee. The notes and
          essays on this site are an attempt to think out loud about the
          craft — the patterns I'm noticing, the questions I'm chewing
          on, the things I keep changing my mind about.
        </p>
        <p>
          If you're working on something interesting, I'd love to hear
          about it.
        </p>
      </div>
    </div>
  </section>

  {/* ---- 3. Subscribe band (single instance on this page) ------------- */}
  <section class="container-phx section subscribe-section">
    <NewsletterBand />
  </section>

  {/* ---- 4. Now preview (top 3) --------------------------------------- */}
  <section class="container-phx section">
    <header class="section-header">
      <h2 class="section-heading">Now</h2>
    </header>
    <p class="now-section-subhead">
      A short preview of what I'm up to.
      <a href="/now" class="section-link">See the full /now →</a>
    </p>
    <div class="now-preview">
      {nowPreview.map((item) => (
        <div class="now-preview-row">
          <span class="now-preview-label">{item.label}</span>
          <span class="now-preview-value">{item.value}</span>
        </div>
      ))}
    </div>
  </section>

  {/* ---- 5. Work history (Timeline) ----------------------------------- */}
  <section class="container-phx section">
    <header class="section-header">
      <h2 class="section-heading">Work History</h2>
    </header>
    <Timeline entries={workHistory} />
  </section>

  {/* ---- 6. Projects — recent 2 --------------------------------------- */}
  <section class="container-phx section">
    <header class="section-header section-header-row">
      <h2 class="section-heading">Projects</h2>
      <Button variant="outline-dark" href="/projects">All projects →</Button>
    </header>
    <div class="project-grid">
      {projects.map((p) => (
        <Card emphasis="lifted">
          <h3 class="project-title">{p.data.title}</h3>
          <p class="project-desc">{p.data.desc}</p>
          <div class="tag-row">
            {p.data.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          <div class="project-cta">
            {p.data.url ? (
              <Button variant="outline" size="sm" href={p.data.url}>View project</Button>
            ) : (
              <Button variant="outline" size="sm" href="/contact">Discuss this project</Button>
            )}
          </div>
        </Card>
      ))}
    </div>
  </section>

  {/* ---- 7. Talks — recent 3 ------------------------------------------ */}
  <section class="container-phx section">
    <header class="section-header section-header-row">
      <h2 class="section-heading">Talks</h2>
      <Button variant="outline-dark" href="/talks">All talks →</Button>
    </header>
    <CollectionGrid cols={3} gap="md">
      {talks.map((talk) => (
        <GardenCard
          title={talk.data.title}
          type="talk"
          excerpt={talk.data.description}
          date={talk.data.date}
          topics={[talk.data.event]}
          href={talk.data.link ?? '#'}
        />
      ))}
    </CollectionGrid>
  </section>

  {/* ---- 8. Skills chip row ------------------------------------------- */}
  <section class="container-phx section">
    <header class="section-header">
      <h2 class="section-heading">Skills</h2>
    </header>
    <ul class="skill-grid">
      {skills.map((s) => <li class="skill-chip">{s}</li>)}
    </ul>
  </section>

  {/* ---- 9. Closing CTA row ------------------------------------------- */}
  <section class="container-phx section cta-section">
    <div class="cta-row">
      <Button variant="primary" href="/garden">See my work</Button>
      <Button variant="outline" href="/contact">Get in touch</Button>
    </div>
  </section>
</Layout>

<style>
  /* --- Page header ---------------------------------------------------- */
  .page-header-section {
    padding-block: var(--spacing-7) var(--spacing-5);
    background: var(--color-neutral-warm);
    border-bottom: 1px solid var(--color-hairline);
  }

  .section-eyebrow {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    font-weight: 600;
    margin-bottom: var(--spacing-2);
  }

  .page-title {
    font-family: var(--font-sans);
    font-size: var(--text-jumbo);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.1;
    margin-bottom: var(--spacing-3);
  }

  @media (min-width: 1024px) {
    .page-title {
      font-size: clamp(3.6rem, 6vw + 1rem, 4.5rem);
    }
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    max-width: 60ch;
  }

  /* --- Section header (h2 + optional right CTA) ---------------------- */
  .section-header {
    margin-bottom: var(--spacing-5);
  }

  .section-header-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--spacing-3);
  }

  .section-heading {
    /* h2 base applies — Inter 600 24px green not used here; we want black. */
    color: var(--color-text-black);
    font-weight: 600;
  }

  .section-link {
    color: var(--color-starbucks-green);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-inline-start: var(--spacing-2);
    transition: color var(--duration-button) ease;
  }

  .section-link:hover {
    color: var(--color-green-accent);
  }

  /* --- Identity grid: prose + portrait photo ------------------------- */
  .identity-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-6);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .identity-grid {
      grid-template-columns: 1fr 18rem;
      gap: var(--spacing-7);
    }
  }

  .identity-photo {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    /* On mobile, stack the photo above the prose. */
    order: -1;
  }

  @media (min-width: 1024px) {
    .identity-photo {
      order: 0;
    }
  }

  .identity-prose {
    /* The shared .prose utility sets 65ch; keep that. */
    max-width: 65ch;
  }

  /* --- Subscribe band wrapper ---------------------------------------- */
  .subscribe-section {
    padding-block: var(--spacing-6);
  }

  @media (min-width: 1024px) {
    .subscribe-section {
      padding-block: var(--spacing-7);
    }
  }

  /* --- Now preview --------------------------------------------------- */
  .now-section-subhead {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-text-black-soft);
    margin-bottom: var(--spacing-5);
    line-height: 1.6;
  }

  .now-preview {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .now-preview-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--spacing-3);
  }

  .now-preview-label {
    font-family: var(--font-sans);
    font-size: var(--text-micro);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    flex-shrink: 0;
    min-width: 9rem;
  }

  .now-preview-value {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-text-black);
    line-height: 1.6;
  }

  /* --- Projects grid ------------------------------------------------- */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  @media (min-width: 768px) {
    .project-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .project-title {
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    margin-bottom: var(--spacing-2);
  }

  .project-desc {
    color: var(--color-text-black-soft);
    line-height: 1.6;
    margin-bottom: var(--spacing-3);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
    margin-bottom: var(--spacing-4);
  }

  .tag {
    font-size: var(--text-micro);
    font-weight: 600;
    color: var(--color-starbucks-green);
    background: var(--color-green-light);
    padding: 4px 10px;
    border-radius: var(--radius-button);
    letter-spacing: var(--tracking-tight);
  }

  .project-cta {
    margin-top: auto;
  }

  /* --- Skills -------------------------------------------------------- */
  .skill-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .skill-chip {
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--color-white);
    border-radius: var(--radius-button);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-starbucks-green);
    box-shadow: var(--shadow-card);
    letter-spacing: var(--tracking-tight);
  }

  /* --- CTA ----------------------------------------------------------- */
  .cta-section {
    padding-top: 0;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }
</style>