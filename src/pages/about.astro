---
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';
import Timeline from '@/components/Timeline.astro';

const workHistory = [
  {
    role: 'Senior Frontend Engineer',
    org: 'Clearhead',
    dates: '2022–Present',
    description: 'Building design systems and React component libraries for a remote-first product team.',
  },
  {
    role: 'Frontend Developer',
    org: 'Freelance',
    dates: '2019–2022',
    description: 'Worked with early-stage startups on landing pages, dashboards, and design system audits.',
  },
  {
    role: 'UI Designer',
    org: 'Studio Nitro',
    dates: '2017–2019',
    description: 'Designed interfaces for mobile apps and web products, collaborating closely with engineering.',
  },
  {
    role: 'Junior Designer',
    org: 'Agency RKT',
    dates: '2015–2017',
    description: 'Production design for marketing sites and branding projects.',
  },
];

const skills = [
  'TypeScript', 'React', 'Astro', 'CSS / Tailwind', 'Node.js', 'PostgreSQL', 'Figma', 'Design Systems',
];
---

<Layout title="About — phurix" description="About Phuriwaj, web developer and designer based in Bangkok.">
  <section class="container-phx section">
    <p class="section-eyebrow">About</p>
    <h1 class="page-title">About Phuriwaj</h1>
    <p class="page-lede">
      I'm a web developer and designer based in Bangkok, building thoughtful interfaces
      and the systems that hold them together.
    </p>
  </section>

  <section class="container-phx section">
    <h2 class="section-heading">Work History</h2>
    <Timeline entries={workHistory} />
  </section>

  <section class="container-phx section">
    <h2 class="section-heading">Gallery</h2>
    <div class="photo-gallery">
      <div class="gallery-item gallery-1"></div>
      <div class="gallery-item gallery-2"></div>
      <div class="gallery-item gallery-3"></div>
    </div>
  </section>

  <section class="container-phx section">
    <Card tone="dark" class="newsletter-card">
      <div class="newsletter-inner">
        <div class="newsletter-text">
          <h2 class="newsletter-headline">Stay in touch</h2>
          <p class="newsletter-blurb">
            Occasional notes from the studio — essays, experiments, and things I'm thinking about.
            No spam, no marketing. Just a short dispatch when there's something worth sharing.
          </p>
        </div>
        <form class="newsletter-form" action="#" method="post">
          <label for="email" class="sr-only">Email address</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="your@email.com"
            class="newsletter-input"
            required
          />
          <Button variant="on-green" type="submit">Subscribe</Button>
        </form>
      </div>
    </Card>
  </section>

  <section class="container-phx section">
    <h2 class="section-heading">Skills</h2>
    <ul class="skill-grid">
      {skills.map((s) => <li class="skill-chip">{s}</li>)}
    </ul>
  </section>

  <section class="container-phx section cta-section">
    <div class="cta-row">
      <Button variant="primary" href="/garden">See my work</Button>
      <Button variant="outline" href="/contact">Get in touch</Button>
    </div>
  </section>
</Layout>

<style>
  .section-eyebrow {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    font-weight: 600;
    margin-bottom: var(--spacing-2);
  }

  .page-title {
    font-size: var(--text-hero-large);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.15;
    margin-bottom: var(--spacing-4);
  }

  .page-lede {
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    max-width: 60ch;
  }

  .section-heading {
    margin-bottom: var(--spacing-5);
    /* h2 base (24/400/text-black) applies; eyebrow above sets hierarchy */
  }

  /* --- Photo Gallery --------------------------------------------- */
  .photo-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  @media (min-width: 768px) {
    .photo-gallery {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery-item {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }

  .gallery-1 { background-color: var(--color-ceramic); }
  .gallery-2 { background-color: var(--color-neutral-cool); }
  .gallery-3 { background-color: var(--color-green-light); }

  /* --- Newsletter Card -------------------------------------------- */
  .newsletter-card {
    padding: var(--spacing-5);
  }

  @media (min-width: 768px) {
    .newsletter-card {
      padding: var(--spacing-6);
    }
  }

  .newsletter-inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }

  @media (min-width: 768px) {
    .newsletter-inner {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--spacing-6);
    }
  }

  .newsletter-text {
    flex: 1;
    max-width: 50ch;
  }

  .newsletter-headline {
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-text-white);
    margin-bottom: var(--spacing-3);
  }

  .newsletter-blurb {
    font-size: var(--text-body);
    color: var(--color-text-white-soft);
    line-height: 1.6;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    min-width: 280px;
  }

  @media (min-width: 480px) {
    .newsletter-form {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .newsletter-input {
    flex: 1;
    padding: 7px 16px;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-black);
    background: var(--color-white);
    border: 1px solid var(--color-input-border);
    border-radius: var(--radius-button);
    outline: none;
    min-width: 0;
    transition: border-color var(--duration-button) ease,
                box-shadow var(--duration-button) ease;
  }

  .newsletter-input::placeholder {
    color: var(--color-text-black-soft);
  }

  .newsletter-input:focus {
    border-color: var(--color-green-accent);
    box-shadow: 0 0 0 2px var(--color-green-accent);
  }

  /* --- Skills ----------------------------------------------------- */
  .skill-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .skill-chip {
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--color-white);
    border-radius: var(--radius-button);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-starbucks-green);
    box-shadow: var(--shadow-card);
    letter-spacing: var(--tracking-tight);
  }

  /* --- CTA ------------------------------------------------------- */
  .cta-section {
    padding-top: 0;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
