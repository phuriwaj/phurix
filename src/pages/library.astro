---
/**
 * /library — A visual shelf of books that shaped thinking.
 * Cite as: DESIGN.md §4 (/library).
 */
import Layout from '@/layouts/Layout.astro';
import BookTile from '@/components/BookTile.astro';
import { getCollection } from 'astro:content';

const allBooks = await getCollection('books');
const books = allBooks.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
---

<Layout title="Library" description="Books that have shaped how I think about design, systems, and the web.">
  <section class="page-header-section">
    <div class="container-phx">
      <p class="section-eyebrow">Shelf</p>
      <h1 class="page-title">Library</h1>
      <p class="page-lede">
        Books that have shaped how I think about design, systems, and the web.
        A working collection — some are reference, some are beloved, all are worn.
      </p>
    </div>
  </section>

  <section class="container-phx section">
    <div class="book-grid">
      {books.map((book) => (
        <BookTile
          title={book.data.title}
          author={book.data.author}
          coverColor={book.data.coverColor}
          year={book.data.year}
          currentlyReading={(book.data as { currentlyReading?: boolean }).currentlyReading}
        />
      ))}
    </div>
    <p class="library-updated">Updated quarterly</p>
  </section>
</Layout>

<style>
  .page-header-section {
    padding-block: var(--spacing-15) var(--spacing-10);
    background: var(--color-soft-stone);
    border-bottom: 1px solid var(--color-hairline);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral-text);
    font-weight: 500;
    margin-bottom: var(--spacing-4);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 6vw, 4.8rem);
    font-weight: 400;
    color: var(--color-heading);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    margin-bottom: var(--spacing-5);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-muted-slate);
    max-width: 60ch;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-8);
  }

  @media (min-width: 640px) {
    .book-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .book-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .library-updated {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted-slate);
    text-align: center;
    margin-block-start: var(--spacing-12);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
  }
</style>
