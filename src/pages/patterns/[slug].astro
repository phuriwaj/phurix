---
import Layout from '@/layouts/Layout.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import { getCollection, render } from 'astro:content';
import { pickArtTopic } from '@/lib/topics';

export async function getStaticPaths() {
  const patterns = await getCollection('patterns');
  return patterns.map((p) => ({
    params: { slug: p.id },
    props: { pattern: p },
  }));
}

const { pattern } = Astro.props;
const { Content } = await render(pattern);
const allTopics = pattern.data.topics ?? [];
const artTopic = pickArtTopic(allTopics);
---

<Layout
  title={`${pattern.data.title} — phurix`}
  description={pattern.data.lede}
>
  <article class="pattern-article">
    <header class="pattern-header container-phx">
      <p class="section-eyebrow">
        <a href="/patterns" class="back-link">← Patterns</a>
      </p>

      <div class="pattern-art">
        <TopicPhoto topic={artTopic} scale="md" />
      </div>

      <h1 class="pattern-h1">{pattern.data.title}</h1>
      <p class="pattern-lede">{pattern.data.lede}</p>
      <div class="pattern-meta-row">
        <time datetime={pattern.data.date.toISOString()} class="pattern-date">
          {pattern.data.date.toLocaleDateString('en-GB', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {allTopics.length > 0 && (
          <ul class="pattern-topics">
            {allTopics.map((t) => <li class="pattern-topic">{t}</li>)}
          </ul>
        )}
      </div>
    </header>

    <div class="pattern-body container-phx">
      <Content />
    </div>

    <footer class="pattern-footer container-phx">
      <a href="/patterns" class="back-link">← Back to all patterns</a>
    </footer>
  </article>
</Layout>

<style>
  .pattern-article {
    padding-block: var(--spacing-7);
  }

  .pattern-header {
    max-width: 65ch;
    margin-bottom: var(--spacing-7);
    margin-inline: auto;
  }

  .pattern-art {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: var(--spacing-5);
    max-width: 32rem;
  }

  .pattern-art :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .section-eyebrow {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    font-weight: 600;
    margin-bottom: var(--spacing-3);
  }

  .back-link {
    color: var(--color-green-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-starbucks-green);
  }

  .pattern-h1 {
    font-size: var(--text-hero-large);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.15;
    margin-bottom: var(--spacing-3);
  }

  .pattern-lede {
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    margin-bottom: var(--spacing-4);
  }

  .pattern-meta-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    flex-wrap: wrap;
    font-size: var(--text-small);
    color: var(--color-text-black-soft);
  }

  .pattern-date { font-weight: 500; }

  .pattern-topics {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--spacing-1);
    flex-wrap: wrap;
  }

  .pattern-topic {
    padding: 4px 10px;
    background: var(--color-green-light);
    color: var(--color-starbucks-green);
    border-radius: var(--radius-button);
    font-size: var(--text-micro);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .pattern-body {
    max-width: 65ch;
    font-size: var(--text-body);
    line-height: 1.7;
    color: var(--color-text-black);
  }

  .pattern-body :global(h2) {
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    margin-top: var(--spacing-6);
    margin-bottom: var(--spacing-3);
  }

  .pattern-body :global(h3) {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--color-text-black);
    margin-top: var(--spacing-5);
    margin-bottom: var(--spacing-2);
  }

  .pattern-body :global(p) {
    margin-bottom: var(--spacing-3);
  }

  .pattern-body :global(ul),
  .pattern-body :global(ol) {
    margin-bottom: var(--spacing-3);
    padding-left: var(--spacing-4);
  }

  .pattern-body :global(li) {
    margin-bottom: var(--spacing-1);
  }

  .pattern-body :global(a) {
    color: var(--color-green-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .pattern-body :global(a:hover) {
    color: var(--color-starbucks-green);
  }

  .pattern-body :global(blockquote) {
    margin: var(--spacing-4) 0;
    padding: var(--spacing-3) var(--spacing-4);
    border-left: 3px solid var(--color-green-accent);
    color: var(--color-text-black-soft);
    font-style: italic;
  }

  .pattern-footer {
    margin-top: var(--spacing-7);
    padding-top: var(--spacing-5);
    border-top: 1px solid var(--color-hairline);
    max-width: 65ch;
  }
</style>