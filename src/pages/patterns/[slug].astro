---
/**
 * Pattern detail — `/patterns/[slug]` (DESIGN.md §4 — read the pattern).
 * Same reading-frame as essay/notes detail. Optional "Used in:" footer
 * line that resolves `related[]` references to other patterns.
 * Cite: DESIGN.md §4 (patterns detail).
 */
import Layout from '@/layouts/Layout.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import { getCollection, render, getEntry } from 'astro:content';
import { pickArtTopic } from '@/lib/topics';

export async function getStaticPaths() {
  const patterns = await getCollection('patterns');
  return patterns.map((p) => ({
    params: { slug: p.id },
    props: { pattern: p },
  }));
}

const { pattern } = Astro.props;
const { Content } = await render(pattern);
const allTopics = pattern.data.topics ?? [];
const artTopic = pickArtTopic(allTopics);

// Resolve related[] references — currently limited to other patterns
// (per src/content.config.ts schema). If the schema ever expands to
// cross-collection references, extend this resolver.
const relatedRefs = pattern.data.related ?? [];
const relatedEntries = await Promise.all(
  relatedRefs.map((ref) => getEntry(ref))
);
const relatedItems = relatedEntries.filter((e): e is NonNullable<typeof e> => Boolean(e));
---

<Layout
  title={`${pattern.data.title} — phurix`}
  description={pattern.data.lede}
  hideFrap
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: pattern.data.title,
      datePublished: pattern.data.date.toISOString(),
      description: pattern.data.lede ?? '',
      keywords: (pattern.data.topics ?? []).join(', '),
      mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
    })}
  />
  <article class="pattern-article">
    <header class="pattern-header container-phx">
      <p class="section-eyebrow">
        <a href="/patterns" class="back-link">← Patterns</a>
      </p>

      <div class="pattern-art">
        <TopicPhoto topic={artTopic} scale="md" showCredit={true} />
      </div>

      <h1 class="pattern-h1">{pattern.data.title}</h1>
      <p class="pattern-lede">{pattern.data.lede}</p>
      <div class="pattern-meta-row">
        <time datetime={pattern.data.date.toISOString()} class="pattern-date">
          {new Intl.DateTimeFormat('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          }).format(new Date(pattern.data.date))}
        </time>
        {allTopics.length > 0 && (
          <ul class="pattern-topics">
            {allTopics.map((t) => <li class="pattern-topic">{t}</li>)}
          </ul>
        )}
      </div>
    </header>

    <div class="pattern-body container-phx">
      <div class="prose">
        <Content />
      </div>
    </div>

    {relatedItems.length > 0 && (
      <aside class="pattern-related container-phx">
        <p class="pattern-related-label">Used in:</p>
        <ul class="pattern-related-list">
          {relatedItems.map((entry, i) => (
            <li>
              <a href={`/patterns/${entry.id}`}>{entry.data.title}</a>
              {i < relatedItems.length - 1 && <span class="pattern-related-sep"> · </span>}
            </li>
          ))}
        </ul>
      </aside>
    )}

    <footer class="pattern-footer container-phx">
      <a href="/patterns" class="back-link">← Back to all patterns</a>
    </footer>
  </article>
</Layout>

<style>
  .pattern-article {
    padding-block: var(--spacing-7);
  }

  .pattern-header {
    max-width: 65ch;
    margin-bottom: var(--spacing-7);
    margin-inline: auto;
  }

  .pattern-art {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: var(--spacing-5);
    max-width: 32rem;
  }

  .pattern-art :global(svg),
  .pattern-art :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .section-eyebrow {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    font-weight: 600;
    margin-bottom: var(--spacing-3);
  }

  .back-link {
    color: var(--color-green-accent);
    font-weight: 600;
    text-decoration: none;
    transition: color var(--duration-button) ease;
  }

  .back-link:hover {
    color: var(--color-starbucks-green);
  }

  /* Title in Lora 600 — matches essay/notes detail (DESIGN.md §1) */
  .pattern-h1 {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.2;
    margin-bottom: var(--spacing-3);
  }

  .pattern-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    margin-bottom: var(--spacing-4);
  }

  .pattern-meta-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    flex-wrap: wrap;
    font-size: var(--text-small);
    color: var(--color-text-black-soft);
  }

  .pattern-date { font-weight: 500; }

  .pattern-topics {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--spacing-1);
    flex-wrap: wrap;
  }

  .pattern-topic {
    padding: 4px 10px;
    background: var(--color-green-light);
    color: var(--color-starbucks-green);
    border-radius: var(--radius-button);
    font-size: var(--text-micro);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .pattern-body {
    max-width: 65ch;
    margin-inline: auto;
  }

  /* "Used in:" footer line — only renders when related[] is populated */
  .pattern-related {
    max-width: 65ch;
    margin-inline: auto;
    margin-top: var(--spacing-6);
    padding-top: var(--spacing-4);
    border-top: 1px solid var(--color-hairline);
  }

  .pattern-related-label {
    font-family: var(--font-sans);
    font-size: var(--text-micro);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    margin-bottom: var(--spacing-2);
  }

  .pattern-related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-text-black);
  }

  .pattern-related-list a {
    color: var(--color-green-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-button) ease;
  }

  .pattern-related-list a:hover {
    color: var(--color-starbucks-green);
  }

  .pattern-related-sep {
    color: var(--color-text-black-soft);
    margin-inline-start: 0.3em;
  }

  .pattern-footer {
    margin-top: var(--spacing-7);
    padding-top: var(--spacing-5);
    border-top: 1px solid var(--color-hairline);
    max-width: 65ch;
  }
</style>