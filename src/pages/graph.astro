---
/**
 * /graph — interactive node-link diagram of topics and entries.
 *
 * Build-time: `buildGraphData()` walks all 7 content collections and emits
 * {nodes, edges}. Inline that JSON into a `<script>` block.
 *
 * Client: a small vanilla-SVG force-directed layout in /src/scripts/graph.ts.
 * Drag-to-pin, click to navigate, filter chips + search for traversal.
 *
 * Cite as: DESIGN.md §7 (Component — graph view).
 */
import Layout from '@/layouts/Layout.astro';
import { buildGraphData } from '@/lib/graph';

const data = await buildGraphData();
---

<Layout
  title="Graph — phurix"
  description="An interactive node-link diagram of topics and entries across the site."
>
  <section class="page-header-section">
    <div class="container-phx">
      <p class="section-eyebrow">Traversal</p>
      <h1 class="page-title">The Graph</h1>
      <p class="page-lede">
        Every topic I write about and every entry I've published, drawn as
        nodes and edges. Topics (soft black) connect to entries (green) that
        carry them; topics that share two or more entries also link, so
        clusters of related reading surface on their own. Drag a node to pin
        it, click to follow it.
      </p>
    </div>
  </section>

  <section class="container-phx graph-controls">
    <div class="graph-toggle" role="group" aria-label="Filter by node type">
      <button type="button" class="graph-toggle-btn" data-filter="both" aria-pressed="true">Both</button>
      <button type="button" class="graph-toggle-btn" data-filter="topics" aria-pressed="false">Topics only</button>
      <button type="button" class="graph-toggle-btn" data-filter="entries" aria-pressed="false">Entries only</button>
    </div>
    <label class="graph-search">
      <span class="sr-only">Search nodes</span>
      <input
        type="search"
        id="graph-search-input"
        placeholder="Search…"
        autocomplete="off"
        spellcheck="false"
      />
    </label>
    <p class="graph-counts">
      <span id="graph-count-nodes">{data.nodes.length}</span> nodes
      ·
      <span id="graph-count-edges">{data.edges.length}</span> edges
    </p>
  </section>

  <section class="container-phx graph-canvas-wrap">
    <div
      id="graph-root"
      class="graph-canvas"
      role="img"
      aria-label="Interactive graph of topics and entries"
    ></div>
    <p class="graph-legend">
      <span class="legend-swatch legend-topic"></span> Topic
      <span class="legend-swatch legend-entry"></span> Entry
      <span class="legend-hint">Drag to pin · click to open · scroll to zoom</span>
    </p>
  </section>

  <script id="graph-data" type="application/json" is:inline set:html={JSON.stringify(data)}></script>
</Layout>

<style>
  .page-header-section {
    padding-block: var(--spacing-15) var(--spacing-10);
    background: var(--color-soft-stone);
    border-bottom: 1px solid var(--color-hairline);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral);
    font-weight: 500;
    margin-bottom: var(--spacing-4);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 6vw, 4.8rem);
    font-weight: 400;
    color: var(--color-cohere-black);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    margin-bottom: var(--spacing-5);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-muted-slate);
    max-width: 65ch;
  }

  .graph-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-5);
    padding-block: var(--spacing-8);
  }

  .graph-toggle {
    display: inline-flex;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--color-canvas);
  }

  .graph-toggle-btn {
    appearance: none;
    border: 0;
    background: transparent;
    padding: var(--spacing-2) var(--spacing-5);
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    color: var(--color-muted-slate);
    cursor: pointer;
    transition:
      background-color var(--duration-button) ease,
      color var(--duration-button) ease;
  }

  .graph-toggle-btn + .graph-toggle-btn {
    border-left: 1px solid var(--color-hairline);
  }

  .graph-toggle-btn[aria-pressed='true'] {
    background: var(--color-near-black);
    color: var(--color-on-dark);
  }

  .graph-search input {
    appearance: none;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    padding: var(--spacing-2) var(--spacing-5);
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    background: var(--color-canvas);
    color: var(--color-ink);
    min-width: 220px;
    outline: none;
    transition: border-color var(--duration-button) ease;
  }

  .graph-search input:focus {
    border-color: var(--color-focus-blue);
  }

  .graph-counts {
    margin: 0 0 0 auto;
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted-slate);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
  }

  .graph-canvas-wrap {
    padding-block: var(--spacing-4) var(--spacing-15);
  }

  .graph-canvas {
    width: 100%;
    height: 80vh;
    min-height: 480px;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    position: relative;
    cursor: grab;
    touch-action: none;
  }

  .graph-canvas.dragging { cursor: grabbing; }

  .graph-canvas :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    user-select: none;
  }

  .graph-canvas :global(circle.gn) {
    cursor: pointer;
    transition: stroke-width 120ms ease;
  }

  .graph-canvas :global(circle.gn-topic) {
    fill: var(--color-muted-slate);
  }

  .graph-canvas :global(circle.gn-entry) {
    fill: var(--color-cohere-black);
  }

  .graph-canvas :global(circle.gn-dim) { opacity: 0.18; }

  .graph-canvas :global(circle.gn-pinned) {
    stroke: var(--color-cohere-black);
    stroke-width: 2;
  }

  .graph-canvas :global(circle.gn-active) {
    stroke: var(--color-coral);
    stroke-width: 2.5;
  }

  .graph-canvas :global(line.ge) {
    stroke: var(--color-hairline);
    stroke-width: 1;
  }

  .graph-canvas :global(line.ge-topic) {
    stroke: var(--color-soft-stone);
    stroke-width: 1.4;
  }

  .graph-canvas :global(line.ge-dim) { opacity: 0.12; }

  .graph-canvas :global(text.glabel) {
    font-family: var(--font-sans);
    font-size: 11px;
    fill: var(--color-ink);
    pointer-events: none;
    paint-order: stroke;
    stroke: var(--color-canvas);
    stroke-width: 3px;
    stroke-linejoin: round;
  }

  .graph-canvas :global(text.glabel-topic) {
    font-weight: 500;
    fill: var(--color-ink);
  }

  .graph-canvas :global(text.glabel-dim) { opacity: 0.2; }

  .graph-legend {
    margin: var(--spacing-5) 0 0;
    font-family: var(--font-sans);
    font-size: var(--text-micro);
    color: var(--color-muted-slate);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-4);
  }

  .legend-swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    margin-inline-end: 4px;
    vertical-align: middle;
  }

  .legend-topic { background: var(--color-muted-slate); }
  .legend-entry { background: var(--color-cohere-black); }

  .legend-hint {
    margin-inline-start: var(--spacing-5);
    color: var(--color-muted-slate);
    opacity: 0.85;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  /**
   * Client-side graph renderer.
   *
   * Reads `GraphData` JSON from #graph-data, builds an SVG with:
   *   - one <line> per edge (topic-topic or entry-topic)
   *   - one <circle> + <text> per node
   *
   * Layout: tiny Verlet-style force simulation.
   *   - repulsion between every pair (O(n^2), fine for n ≤ ~200)
   *   - spring along every edge
   *   - gentle gravity toward canvas center
   *   - drag pins a node; release unpins
   *
   * Drag is in screen pixels; physics is in canvas units. We track a zoom/
   * pan transform applied at draw time so the simulation stays in a sane
   * coordinate range.
   *
   * Filter: "Topics only" / "Entries only" / "Both" hides non-matching nodes
   * and the edges incident to them. Search: case-insensitive substring on
   * the label — matching nodes stay full opacity, others dim to 18%.
   */

  type Kind = 'topic' | 'entry';
  interface GNode {
    id: string;
    label: string;
    kind: Kind;
    href?: string;
    meta?: { date?: string; collection?: string };
  }
  interface GEdge { source: string; target: string }
  interface GData { nodes: GNode[]; edges: GEdge[] }

  interface SimNode {
    id: string;
    label: string;
    kind: Kind;
    href?: string;
    x: number;
    y: number;
    vx: number;
    vy: number;
    pinned: boolean;
  }

  function init() {
    const rootEl = document.getElementById('graph-root');
    const dataEl = document.getElementById('graph-data');
    if (!rootEl || !dataEl) return;
    const root: HTMLElement = rootEl;
    const dataScript = dataEl as HTMLScriptElement;

    let data: GData;
    try {
      data = JSON.parse(dataScript.textContent || '{}') as GData;
    } catch {
      return;
    }
    if (!data?.nodes?.length) return;

    // Layout canvas (viewBox-ish units — the SVG uses preserveAspectRatio to scale).
    const W = 1200;
    const H = 800;

    // Precompute degree for node radius.
    const degree = new Map<string, number>();
    for (const n of data.nodes) degree.set(n.id, 0);
    for (const e of data.edges) {
      degree.set(e.source, (degree.get(e.source) ?? 0) + 1);
      degree.set(e.target, (degree.get(e.target) ?? 0) + 1);
    }

    // Seed positions: topics in an inner ring, entries in an outer ring,
    // arranged by hash so the layout is deterministic between reloads.
    function hash(s: string): number {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return (h >>> 0) / 0xffffffff;
    }
    const topics = data.nodes.filter((n) => n.kind === 'topic');
    const entries = data.nodes.filter((n) => n.kind === 'entry');
    const sim: SimNode[] = [];

    topics.forEach((n, i) => {
      const a = (i / Math.max(topics.length, 1)) * Math.PI * 2;
      const r = 160 + hash(n.id) * 40;
      sim.push({
        id: n.id,
        label: n.label,
        kind: n.kind,
        href: n.href,
        x: W / 2 + Math.cos(a) * r,
        y: H / 2 + Math.sin(a) * r,
        vx: 0,
        vy: 0,
        pinned: false,
      });
    });
    entries.forEach((n) => {
      const a = hash(n.id) * Math.PI * 2;
      const r = 280 + hash(n.id) * 220;
      sim.push({
        id: n.id,
        label: n.label,
        kind: n.kind,
        href: n.href,
        x: W / 2 + Math.cos(a) * r,
        y: H / 2 + Math.sin(a) * r,
        vx: 0,
        vy: 0,
        pinned: false,
      });
    });

    const idx = new Map(sim.map((s) => [s.id, s]));

    // Adjacency for spring lookups.
    const adj = new Map<string, Set<string>>();
    for (const s of sim) adj.set(s.id, new Set());
    for (const e of data.edges) {
      adj.get(e.source)?.add(e.target);
      adj.get(e.target)?.add(e.source);
    }

    // Build SVG.
    const svgNS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNS, 'svg');
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

    const edgeLayer = document.createElementNS(svgNS, 'g');
    edgeLayer.setAttribute('class', 'edges');
    const nodeLayer = document.createElementNS(svgNS, 'g');
    nodeLayer.setAttribute('class', 'nodes');
    svg.append(edgeLayer, nodeLayer);
    root.replaceChildren(svg);

    // Edges.
    const edgeEls = new Map<string, SVGLineElement>();
    for (const e of data.edges) {
      const a = idx.get(e.source);
      const b = idx.get(e.target);
      if (!a || !b) continue;
      const line = document.createElementNS(svgNS, 'line');
      line.setAttribute('class', 'ge' + (a.kind === 'topic' && b.kind === 'topic' ? ' ge-topic' : ''));
      edgeLayer.append(line);
      edgeEls.set(e.source + '|' + e.target, line);
      edgeEls.set(e.target + '|' + e.source, line);
    }

    // Nodes.
    const nodeEls = new Map<string, SVGGElement>();
    const circleEls = new Map<string, SVGCircleElement>();
    const labelEls = new Map<string, SVGTextElement>();
    for (const s of sim) {
      const g = document.createElementNS(svgNS, 'g');
      g.setAttribute('class', 'gn-group');
      const c = document.createElementNS(svgNS, 'circle');
      const r = 5 + Math.min(14, Math.sqrt(degree.get(s.id) ?? 1) * 2.6);
      c.setAttribute('r', String(r));
      c.setAttribute('class', 'gn gn-' + s.kind);
      const t = document.createElementNS(svgNS, 'text');
      t.setAttribute('class', 'glabel glabel-' + s.kind);
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('dy', String(-(r + 4)));
      t.textContent = s.label;
      g.append(c, t);
      nodeLayer.append(g);
      nodeEls.set(s.id, g);
      circleEls.set(s.id, c);
      labelEls.set(s.id, t);
    }

    // Force simulation (Verlet-ish).
    const REPULSION = 1800;
    const SPRING_LEN = 110;
    const SPRING_K = 0.04;
    const GRAVITY = 0.012;
    const DAMPING = 0.82;
    const MAX_VEL = 18;

    function step() {
      // Repulsion (O(n^2)).
      for (let i = 0; i < sim.length; i++) {
        const a = sim[i];
        for (let j = i + 1; j < sim.length; j++) {
          const b = sim[j];
          const dx = b.x - a.x;
          const dy = b.y - a.y;
          let d2 = dx * dx + dy * dy;
          if (d2 < 0.01) d2 = 0.01;
          const d = Math.sqrt(d2);
          const f = REPULSION / d2;
          const fx = (dx / d) * f;
          const fy = (dy / d) * f;
          a.vx -= fx;
          a.vy -= fy;
          b.vx += fx;
          b.vy += fy;
        }
      }
      // Springs along edges.
      for (const e of data.edges) {
        const a = idx.get(e.source);
        const b = idx.get(e.target);
        if (!a || !b) continue;
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const d = Math.sqrt(dx * dx + dy * dy) || 0.01;
        const target = e.source.startsWith('topic:') && e.target.startsWith('topic:') ? SPRING_LEN * 1.6 : SPRING_LEN;
        const f = (d - target) * SPRING_K;
        const fx = (dx / d) * f;
        const fy = (dy / d) * f;
        a.vx += fx;
        a.vy += fy;
        b.vx -= fx;
        b.vy -= fy;
      }
      // Gravity + integrate.
      for (const s of sim) {
        if (s.pinned) { s.vx = 0; s.vy = 0; continue; }
        s.vx += (W / 2 - s.x) * GRAVITY;
        s.vy += (H / 2 - s.y) * GRAVITY;
        s.vx *= DAMPING;
        s.vy *= DAMPING;
        if (s.vx > MAX_VEL) s.vx = MAX_VEL;
        if (s.vx < -MAX_VEL) s.vx = -MAX_VEL;
        if (s.vy > MAX_VEL) s.vy = MAX_VEL;
        if (s.vy < -MAX_VEL) s.vy = -MAX_VEL;
        s.x += s.vx;
        s.y += s.vy;
        // Soft clamp inside the canvas with a margin.
        const m = 40;
        if (s.x < m) { s.x = m; s.vx *= -0.4; }
        if (s.x > W - m) { s.x = W - m; s.vx *= -0.4; }
        if (s.y < m) { s.y = m; s.vy *= -0.4; }
        if (s.y > H - m) { s.y = H - m; s.vy *= -0.4; }
      }
    }

    function render() {
      for (const s of sim) {
        const g = nodeEls.get(s.id);
        if (g) g.setAttribute('transform', `translate(${s.x.toFixed(1)},${s.y.toFixed(1)})`);
      }
      for (const e of data.edges) {
        const a = idx.get(e.source);
        const b = idx.get(e.target);
        if (!a || !b) continue;
        const line = edgeEls.get(e.source + '|' + e.target);
        if (line) {
          line.setAttribute('x1', a.x.toFixed(1));
          line.setAttribute('y1', a.y.toFixed(1));
          line.setAttribute('x2', b.x.toFixed(1));
          line.setAttribute('y2', b.y.toFixed(1));
        }
      }
    }

    // Map screen px to viewBox units via the SVG's CTM.
    function clientToSvg(clientX: number, clientY: number): { x: number; y: number } {
      const pt = svg.createSVGPoint();
      pt.x = clientX;
      pt.y = clientY;
      const ctm = svg.getScreenCTM();
      if (!ctm) return { x: clientX, y: clientY };
      const inv = ctm.inverse();
      const out = pt.matrixTransform(inv);
      return { x: out.x, y: out.y };
    }

    // Drag a node.
    let dragging: SimNode | null = null;
    let dragMoved = false;
    let dragStart = { x: 0, y: 0, nodeX: 0, nodeY: 0 };

    function onPointerDown(ev: PointerEvent) {
      const target = ev.target as Element | null;
      const g = target?.closest('g.gn-group') as SVGGElement | null;
      if (!g) return;
      const id = g.getAttribute('data-id');
      if (!id) return;
      const s = idx.get(id);
      if (!s) return;
      dragging = s;
      dragMoved = false;
      dragStart = { x: ev.clientX, y: ev.clientY, nodeX: s.x, nodeY: s.y };
      s.pinned = true;
      g.setPointerCapture(ev.pointerId);
      root.classList.add('dragging');
      const c = circleEls.get(s.id);
      c?.classList.add('gn-pinned');
    }

    function onPointerMove(ev: PointerEvent) {
      if (!dragging) return;
      const dx = ev.clientX - dragStart.x;
      const dy = ev.clientY - dragStart.y;
      if (Math.abs(dx) + Math.abs(dy) > 3) dragMoved = true;
      const cur = clientToSvg(ev.clientX, ev.clientY);
      const start = clientToSvg(dragStart.x, dragStart.y);
      dragging.x = dragStart.nodeX + (cur.x - start.x);
      dragging.y = dragStart.nodeY + (cur.y - start.y);
    }

    function onPointerUp(ev: PointerEvent) {
      if (!dragging) return;
      const wasMoved = dragMoved;
      const node = dragging;
      const wasTopic = node.kind === 'topic';
      const topicLabel = node.label;
      const href = node.href;
      // Unpin unless the user moved (drag, not click).
      node.pinned = false;
      const c = circleEls.get(node.id);
      c?.classList.remove('gn-pinned');
      try {
        (nodeEls.get(node.id) as SVGGElement).releasePointerCapture(ev.pointerId);
      } catch { /* ignore */ }
      dragging = null;
      root.classList.remove('dragging');
      if (!wasMoved) {
        if (wasTopic) {
          window.location.href = '/garden?topic=' + encodeURIComponent(topicLabel);
        } else if (href) {
          window.location.href = href;
        }
      }
    }

    svg.addEventListener('pointerdown', onPointerDown);
    svg.addEventListener('pointermove', onPointerMove);
    svg.addEventListener('pointerup', onPointerUp);
    svg.addEventListener('pointercancel', onPointerUp);

    // Tag each node group with its id for the drag handler.
    for (const s of sim) {
      const g = nodeEls.get(s.id);
      if (g) g.setAttribute('data-id', s.id);
    }

    // Animation loop — bail after the layout settles or after ~6s.
    let frames = 0;
    const MAX_FRAMES = 360;
    function tick() {
      step();
      render();
      frames++;
      const moving = sim.some((s) => !s.pinned && (Math.abs(s.vx) + Math.abs(s.vy) > 0.4));
      if (moving && frames < MAX_FRAMES) {
        requestAnimationFrame(tick);
      } else {
        // One last settle step.
        for (let i = 0; i < 30; i++) step();
        render();
      }
    }
    requestAnimationFrame(tick);

    // --- Filter + search ---
    let activeFilter: 'both' | 'topics' | 'entries' = 'both';
    let query = '';

    function applyFilter() {
      const q = query.trim().toLowerCase();
      for (const s of sim) {
        const c = circleEls.get(s.id);
        const t = labelEls.get(s.id);
        const matchesKind =
          activeFilter === 'both' ||
          (activeFilter === 'topics' && s.kind === 'topic') ||
          (activeFilter === 'entries' && s.kind === 'entry');
        const matchesQuery = q === '' || s.label.toLowerCase().includes(q);
        const visible = matchesKind && matchesQuery;
        if (c) c.classList.toggle('gn-dim', !visible);
        if (t) t.classList.toggle('glabel-dim', !visible);
      }
      for (const [key, line] of edgeEls) {
        const [a, b] = key.split('|');
        if (!idx.get(a) || !idx.get(b)) continue;
        const ra = circleEls.get(a);
        const rb = circleEls.get(b);
        const dimA = ra?.classList.contains('gn-dim');
        const dimB = rb?.classList.contains('gn-dim');
        line.classList.toggle('ge-dim', !!(dimA || dimB));
      }
    }

    // Wire toggle buttons.
    const buttons = root.parentElement?.querySelectorAll<HTMLButtonElement>('.graph-toggle-btn');
    buttons?.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => {
          b.classList.remove('topic-chip-active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('topic-chip-active');
        btn.setAttribute('aria-pressed', 'true');
        const f = btn.dataset.filter;
        if (f === 'topics' || f === 'entries' || f === 'both') activeFilter = f;
        applyFilter();
      });
    });

    // Wire search.
    const searchInput = document.getElementById('graph-search-input') as HTMLInputElement | null;
    searchInput?.addEventListener('input', () => {
      query = searchInput.value;
      applyFilter();
    });
  }

