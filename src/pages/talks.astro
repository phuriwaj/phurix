---
/**
 * /talks — A sparse, external-link-heavy index of public speaking.
 * Cite as: DESIGN.md §4 (/talks) — row list mirrors bibliographic form.
 */
import Layout from '@/layouts/Layout.astro';
import TopicChip from '@/components/TopicChip.astro';
import { getCollection } from 'astro:content';

const allTalks = await getCollection('talks');
const talks = allTalks.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout title="Talks" description="Conference talks and workshop sessions.">
  <section class="page-header-section">
    <div class="container-phx">
      <h1 class="page-title">Talks</h1>
      <p class="page-lede">
        Conference talks and workshop sessions on design systems,
        component architecture, and the quieter ideas underneath.
      </p>
    </div>
  </section>

  <section class="container-phx section">
    {talks.length === 0 ? (
      <p class="empty">No talks to show — yet.</p>
    ) : (
      <ul class="talk-list">
        {talks.map((talk) => {
          const href = talk.data.link;
          const inner = (
            <>
              <div class="talk-body">
                <h2 class="talk-title">{talk.data.title}</h2>
                <p class="talk-description">{talk.data.description}</p>
                {talk.data.event && (
                  <div class="talk-event-wrap">
                    <TopicChip label={talk.data.event} size="sm" />
                  </div>
                )}
              </div>
              <div class="talk-meta">
                <time class="talk-date" datetime={talk.data.date.toISOString()}>
                  {dateFmt.format(talk.data.date)}
                </time>
                {href && <span class="talk-external" aria-hidden="true">↗</span>}
              </div>
            </>
          );
          return (
            <li class="talk-row-item">
              {href ? (
                <a
                  href={href}
                  class="talk-row talk-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {inner}
                </a>
              ) : (
                <div class="talk-row talk-row-nolink">{inner}</div>
              )}
            </li>
          );
        })}
      </ul>
    )}

    <p class="talks-closing">
      For workshop enquiries: <a href="/contact">contact me</a>.
    </p>
  </section>
</Layout>

<style>
  .page-header-section {
    padding-block: var(--spacing-15) var(--spacing-10);
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 6vw, 4.8rem);
    font-weight: 400;
    color: var(--color-heading);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    margin-bottom: var(--spacing-5);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-muted-slate);
    max-width: 60ch;
  }

  .talk-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .talk-row-item {
    border-bottom: 1px solid var(--color-hairline);
  }

  .talk-row-item:first-child {
    border-top: 1px solid var(--color-hairline);
  }

  .talk-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-5);
    padding-block: var(--spacing-8);
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-button) ease;
    align-items: center;
  }

  @media (min-width: 768px) {
    .talk-row {
      grid-template-columns: 1fr 12rem 10rem;
      gap: var(--spacing-12);
    }
  }

  .talk-link:hover {
    color: var(--color-action-blue);
  }

  .talk-body {
    min-width: 0;
  }

  .talk-title {
    font-family: var(--font-display);
    font-size: var(--text-feature-heading);
    font-weight: 400;
    color: var(--color-ink);
    margin: 0 0 var(--spacing-4);
    letter-spacing: var(--tracking-display-tight);
    transition: color var(--duration-button) ease;
  }

  .talk-link:hover .talk-title {
    color: var(--color-action-blue);
  }

  .talk-description {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--color-muted-slate);
    max-width: 65ch;
    margin: 0 0 var(--spacing-4);
  }

  .talk-event-wrap {
    display: flex;
  }

  .talk-meta {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--spacing-4);
    font-family: var(--font-mono);
    justify-content: flex-start;
  }

  @media (min-width: 768px) {
    .talk-meta {
      justify-content: center;
    }
  }

  .talk-date {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-muted-slate);
    letter-spacing: var(--tracking-mono);
  }

  .talk-external {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    color: var(--color-action-blue);
    opacity: 0;
    transition: opacity var(--duration-button) ease;
  }

  .talk-link:hover .talk-external,
  .talk-link:focus-visible .talk-external {
    opacity: 1;
  }

  .talks-closing {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-muted-slate);
    margin-block-start: var(--spacing-12);
  }

  .talks-closing a {
    color: var(--color-action-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-button) ease;
  }

  .talks-closing a:hover {
    color: var(--color-heading);
  }

  .empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-muted-slate);
  }
</style>
