---
/**
 * /talks — A sparse, external-link-heavy index of public speaking.
 * Cite as: DESIGN.md §4 (/talks) — row list mirrors bibliographic form.
 */
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTalks = await getCollection('talks');
const talks = allTalks.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout title="Talks" description="Conference talks and workshop sessions.">
  <section class="page-header-section">
    <div class="container-phx">
      <h1 class="page-title">Talks</h1>
      <p class="page-lede">
        Conference talks and workshop sessions on design systems,
        component architecture, and the quieter ideas underneath.
      </p>
    </div>
  </section>

  <section class="container-phx section">
    {talks.length === 0 ? (
      <p class="empty">No talks to show — yet.</p>
    ) : (
      <ul class="talk-list">
        {talks.map((talk) => {
          const href = talk.data.link;
          const inner = (
            <>
              <div class="talk-body">
                <h2 class="talk-title">{talk.data.title}</h2>
                <p class="talk-description">{talk.data.description}</p>
              </div>
              <div class="talk-meta">
                <span class="talk-event">{talk.data.event}</span>
                <time class="talk-date" datetime={talk.data.date.toISOString()}>
                  {dateFmt.format(talk.data.date)}
                </time>
                {href && <span class="talk-external" aria-hidden="true">↗</span>}
              </div>
            </>
          );
          return (
            <li class="talk-row-item">
              {href ? (
                <a
                  href={href}
                  class="talk-row talk-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {inner}
                </a>
              ) : (
                <div class="talk-row talk-row-nolink">{inner}</div>
              )}
            </li>
          );
        })}
      </ul>
    )}

    <p class="talks-closing">
      For workshop enquiries: <a href="/contact">contact me</a>.
    </p>
  </section>
</Layout>

<style>
  .page-header-section {
    padding-block: var(--spacing-7) var(--spacing-5);
    background: var(--color-neutral-warm);
    border-bottom: 1px solid var(--color-hairline);
  }

  .page-title {
    font-size: clamp(3.6rem, 6vw + 1rem, 4.5rem);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.1;
    margin-bottom: var(--spacing-3);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    max-width: 60ch;
  }

  .talk-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .talk-row-item {
    border-bottom: 1px solid var(--color-hairline);
  }

  .talk-row-item:first-child {
    border-top: 1px solid var(--color-hairline);
  }

  .talk-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
    padding-block: var(--spacing-5);
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-button) ease;
  }

  @media (min-width: 768px) {
    .talk-row {
      grid-template-columns: 1fr 10rem;
      align-items: start;
      gap: var(--spacing-6);
    }
  }

  .talk-link:hover {
    color: var(--color-starbucks-green);
  }

  .talk-title {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    margin-bottom: var(--spacing-2);
    transition: color var(--duration-button) ease;
  }

  .talk-link:hover .talk-title {
    color: var(--color-green-accent);
  }

  .talk-description {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    max-width: 65ch;
  }

  .talk-meta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    font-family: var(--font-sans);
  }

  @media (min-width: 768px) {
    .talk-meta {
      align-items: flex-end;
      text-align: right;
    }
  }

  .talk-event {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    font-size: var(--text-micro);
    color: var(--color-starbucks-green);
  }

  .talk-date {
    font-size: var(--text-small);
    color: var(--color-text-black-soft);
  }

  .talk-external {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-starbucks-green);
    opacity: 0;
    transition: opacity var(--duration-button) ease;
  }

  .talk-link:hover .talk-external,
  .talk-link:focus-visible .talk-external {
    opacity: 1;
  }

  .talks-closing {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-text-black-soft);
    margin-block-start: var(--spacing-6);
  }

  .talks-closing a {
    color: var(--color-green-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-button) ease;
  }

  .talks-closing a:hover {
    color: var(--color-starbucks-green);
  }

  .empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-text-black-soft);
  }
</style>