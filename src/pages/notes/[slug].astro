---
/**
 * Note detail — `/notes/[slug]` (DESIGN.md §4 — read the note).
 * Same reading-frame as essay detail, no hero unless growthStage === 'evergreen'.
 * Cite: DESIGN.md §4 (notes detail).
 */
import Layout from '@/layouts/Layout.astro';
import TopicChip from '@/components/TopicChip.astro';
import GrowthBadge from '@/components/GrowthBadge.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import { getCollection, render, getEntry } from 'astro:content';
import { pickArtTopic } from '@/lib/topics';
import { findBacklinks } from '@/lib/backlinks';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allNotes = await getCollection('notes');
const sortedNotes = allNotes.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const currentIndex = sortedNotes.findIndex((n) => n.id === entry.id);
const prevNote = currentIndex < sortedNotes.length - 1 ? sortedNotes[currentIndex + 1] : null;
const nextNote = currentIndex > 0 ? sortedNotes[currentIndex - 1] : null;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(entry.data.date));

const artTopic = pickArtTopic(entry.data.topics);

const relatedRefs = entry.data.related ?? [];
const relatedResolved = await Promise.all(
  relatedRefs.map((ref) => getEntry(ref))
);
const relatedItems = relatedResolved.filter(
  (e): e is NonNullable<typeof e> => Boolean(e)
);

const allNotesForBacklinks = await getCollection('notes');
const allEssaysForBacklinks = await getCollection('essays');
const allPatternsForBacklinks = await getCollection('patterns');
const backlinkSources = [
  ...findBacklinks(entry.id, 'notes', allNotesForBacklinks),
  ...findBacklinks(entry.id, 'notes', allEssaysForBacklinks),
  ...findBacklinks(entry.id, 'notes', allPatternsForBacklinks),
].filter(({ entry: source }) => source.id !== entry.id);
---

<Layout title={entry.data.title} description={entry.data.excerpt} hideAnnouncement>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: entry.data.title,
      datePublished: entry.data.date.toISOString(),
      description: entry.data.excerpt ?? '',
      keywords: (entry.data.topics ?? []).join(', '),
      mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
    })}
  />
  <section class="section">
    <div class="container-phx">
      <a href="/notes" class="back-link">← Notes</a>

      <article class="note-article">
        <header class="note-header">
          {entry.data.growthStage === 'evergreen' && (
            <div class="note-art">
              <TopicPhoto topic={artTopic} scale="md" showCredit={true} />
            </div>
          )}

          <h1 class="note-title">{entry.data.title}</h1>

          <div class="note-meta">
            <time class="note-date" datetime={entry.data.date.toISOString()}>
              {formattedDate}
            </time>
            <span class="note-divider">·</span>
            {entry.data.growthStage && (
              <GrowthBadge stage={entry.data.growthStage} size="md" />
            )}
            <span class="note-divider">·</span>
            <span class="note-read-time">{Math.max(1, Math.round((entry.body ?? '').split(/\s+/).length / 220))} min read</span>
          </div>

          {entry.data.topics && entry.data.topics.length > 0 && (
            <div class="note-topics">
              {entry.data.topics.map((t) => <TopicChip label={t} size="sm" href={`/garden?topic=${t}`} />)}
            </div>
          )}
        </header>

        <div class="prose">
          <Content />
        </div>

        <nav class="note-nav">
          {prevNote && (
            <a href={`/notes/${prevNote.id}`} class="note-nav-link note-nav-prev">
              ← {prevNote.data.title}
            </a>
          )}
          {nextNote && (
            <a href={`/notes/${nextNote.id}`} class="note-nav-link note-nav-next">
              {nextNote.data.title} →
            </a>
          )}
        </nav>

        {(relatedItems.length > 0 || backlinkSources.length > 0) && (
          <aside class="note-links">
            {relatedItems.length > 0 && (
              <section class="note-links-section">
                <p class="note-links-label">Related</p>
                <ul class="note-links-list">
                  {relatedItems.map((rel, i) => (
                    <li>
                      <a href={`/notes/${rel.id}`}>{rel.data.title}</a>
                      {i < relatedItems.length - 1 && <span class="note-links-sep"> · </span>}
                    </li>
                  ))}
                </ul>
              </section>
            )}

            {relatedItems.length > 0 && backlinkSources.length > 0 && (
              <hr class="note-links-divider" />
            )}

            {backlinkSources.length > 0 && (
              <section class="note-links-section">
                <p class="note-links-label">Linked from</p>
                <ul class="note-links-list">
                  {backlinkSources.map(({ entry: source, collection: coll }, i) => (
                    <li>
                      <span class="note-links-collection">{coll}/</span>
                      <a href={`/${coll}/${source.id}`}>{source.data.title}</a>
                      {i < backlinkSources.length - 1 && <span class="note-links-sep"> · </span>}
                    </li>
                  ))}
                </ul>
              </section>
            )}
          </aside>
        )}
      </article>
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-action-blue);
    text-decoration: none;
    margin-bottom: var(--spacing-8);
    transition: color var(--duration-button) ease;
  }

  .back-link:hover {
    color: var(--color-heading);
  }

  .note-article {
    max-width: 65ch;
    margin-inline: auto;
  }

  .note-header {
    margin-bottom: var(--spacing-12);
  }

  .note-art {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--spacing-8);
    max-width: 32rem;
  }

  .note-art :global(svg),
  .note-art :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .note-title {
    font-family: var(--font-display);
    font-size: var(--text-card-heading);
    font-weight: 400;
    color: var(--color-heading);
    line-height: 1.15;
    letter-spacing: var(--tracking-display-tight);
    margin-bottom: var(--spacing-5);
  }

  .note-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-5);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted-slate);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
  }

  .note-divider { opacity: 0.5; }

  .note-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .note-nav {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-5);
    margin-top: var(--spacing-15);
    padding-top: var(--spacing-8);
    border-top: 1px solid var(--color-hairline);
  }

  .note-nav-link {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-action-blue);
    text-decoration: none;
    transition: color var(--duration-button) ease;
  }

  .note-nav-link:hover {
    color: var(--color-heading);
  }

  .note-nav-next {
    margin-left: auto;
  }

  .note-article .prose {
    line-height: 1.65;
  }

  .note-links {
    margin-top: var(--spacing-15);
    padding-top: var(--spacing-8);
    border-top: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-7);
  }

  .note-links-section + .note-links-section {
    padding-top: var(--spacing-7);
  }

  .note-links-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .note-links-divider {
    border: 0;
    border-top: 1px solid var(--color-hairline);
    margin: 0;
  }

  .note-links-label {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral-text);
  }

  .note-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-ink);
  }

  .note-links-list a {
    color: var(--color-action-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-button) ease;
  }

  .note-links-list a:hover {
    color: var(--color-heading);
  }

  .note-links-collection {
    color: var(--color-muted-slate);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    margin-inline-end: 0.2em;
    letter-spacing: var(--tracking-mono);
  }

  .note-links-sep {
    color: var(--color-muted-slate);
    margin-inline-start: 0.3em;
  }
</style>
