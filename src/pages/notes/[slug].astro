---
import Layout from '@/layouts/Layout.astro';
import TopicChip from '@/components/TopicChip.astro';
import GrowthBadge from '@/components/GrowthBadge.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import { getCollection, render } from 'astro:content';
import { pickArtTopic } from '@/lib/topics';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allNotes = await getCollection('notes');
const sortedNotes = allNotes.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const currentIndex = sortedNotes.findIndex((n) => n.id === entry.id);
const prevNote = currentIndex < sortedNotes.length - 1 ? sortedNotes[currentIndex + 1] : null;
const nextNote = currentIndex > 0 ? sortedNotes[currentIndex - 1] : null;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(entry.data.date));

const artTopic = pickArtTopic(entry.data.topics);
---

<Layout title={entry.data.title} description={entry.data.excerpt}>
  <section class="section">
    <div class="container-phx">
      <a href="/notes" class="back-link">← Notes</a>

      <article class="note-article">
        <header class="note-header">
          <div class="note-art">
            <TopicPhoto topic={artTopic} scale="md" />
          </div>

          <h1 class="note-title">{entry.data.title}</h1>

          <div class="note-meta">
            <time class="note-date" datetime={entry.data.date.toISOString()}>
              {formattedDate}
            </time>
            {entry.data.growthStage && (
              <GrowthBadge stage={entry.data.growthStage} />
            )}
          </div>

          {entry.data.topics && entry.data.topics.length > 0 && (
            <div class="note-topics">
              {entry.data.topics.map((t) => <TopicChip label={t} />)}
            </div>
          )}
        </header>

        <div class="prose">
          <Content />
        </div>

        <nav class="note-nav">
          {prevNote && (
            <a href={`/notes/${prevNote.id}`} class="note-nav-link note-nav-prev">
              ← {prevNote.data.title}
            </a>
          )}
          {nextNote && (
            <a href={`/notes/${nextNote.id}`} class="note-nav-link note-nav-next">
              {nextNote.data.title} →
            </a>
          )}
        </nav>
      </article>
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green-accent);
    text-decoration: none;
    margin-bottom: var(--spacing-5);
    transition: color var(--duration-button) ease;
  }

  .back-link:hover {
    color: var(--color-starbucks-green);
  }

  .note-article {
    max-width: 65ch;
    margin-inline: auto;
  }

  .note-header {
    margin-bottom: var(--spacing-6);
  }

  .note-art {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: var(--spacing-5);
    max-width: 36rem;
  }

  .note-art :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .note-title {
    font-size: var(--text-hero-large);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.15;
    margin-bottom: var(--spacing-3);
  }

  .note-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    margin-bottom: var(--spacing-3);
  }

  .note-date {
    font-size: var(--text-small);
    color: var(--color-text-black-soft);
  }

  .note-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
  }

  .note-nav {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-top: var(--spacing-7);
    padding-top: var(--spacing-5);
    border-top: 1px solid var(--color-hairline);
  }

  .note-nav-link {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green-accent);
    text-decoration: none;
    transition: color var(--duration-button) ease;
  }

  .note-nav-link:hover {
    color: var(--color-starbucks-green);
  }

  .note-nav-next {
    margin-left: auto;
  }

  /* --- Prose styles ------------------------------------------------ */
  .prose {
    max-width: 65ch;
  }

  .prose :global(h2) {
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    margin-top: var(--spacing-6);
    margin-bottom: var(--spacing-3);
  }

  .prose :global(h3) {
    font-size: var(--text-body-lg);
    font-weight: 600;
    color: var(--color-text-black);
    margin-top: var(--spacing-5);
    margin-bottom: var(--spacing-2);
  }

  .prose :global(p) {
    color: var(--color-text-black);
    line-height: 1.75;
    margin-bottom: var(--spacing-4);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--spacing-5);
    margin-bottom: var(--spacing-4);
  }

  .prose :global(li) {
    color: var(--color-text-black-soft);
    margin-bottom: var(--spacing-2);
    line-height: 1.7;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-green-accent);
    padding-left: var(--spacing-4);
    margin-left: 0;
    font-style: italic;
    color: var(--color-text-black-soft);
  }

  .prose :global(code) {
    background: var(--color-ceramic);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--color-house-green);
    color: var(--color-text-white);
    padding: var(--spacing-4);
    border-radius: var(--radius-card);
    overflow-x: auto;
    margin-bottom: var(--spacing-4);
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(a) {
    color: var(--color-green-accent);
    text-decoration: underline;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-text-black);
  }
</style>
