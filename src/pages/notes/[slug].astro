---
/**
 * Note detail — `/notes/[slug]` (DESIGN.md §4 — read the note).
 * Same reading-frame as essay detail, no hero unless growthStage === 'evergreen'.
 * Cite: DESIGN.md §4 (notes detail).
 */
import Layout from '@/layouts/Layout.astro';
import TopicChip from '@/components/TopicChip.astro';
import GrowthBadge from '@/components/GrowthBadge.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import { getCollection, render } from 'astro:content';
import { pickArtTopic } from '@/lib/topics';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allNotes = await getCollection('notes');
const sortedNotes = allNotes.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const currentIndex = sortedNotes.findIndex((n) => n.id === entry.id);
const prevNote = currentIndex < sortedNotes.length - 1 ? sortedNotes[currentIndex + 1] : null;
const nextNote = currentIndex > 0 ? sortedNotes[currentIndex - 1] : null;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(entry.data.date));

const artTopic = pickArtTopic(entry.data.topics);
---

<Layout title={entry.data.title} description={entry.data.excerpt} hideFrap>
  <section class="section">
    <div class="container-phx">
      <a href="/notes" class="back-link">← Notes</a>

      <article class="note-article">
        <header class="note-header">
          {entry.data.growthStage === 'evergreen' && (
            <div class="note-art">
              <TopicPhoto topic={artTopic} scale="md" showCredit={true} />
            </div>
          )}

          <h1 class="note-title">{entry.data.title}</h1>

          <div class="note-meta">
            <time class="note-date" datetime={entry.data.date.toISOString()}>
              {formattedDate}
            </time>
            <span class="note-divider">·</span>
            {entry.data.growthStage && (
              <GrowthBadge stage={entry.data.growthStage} size="md" />
            )}
            <span class="note-divider">·</span>
            <span class="note-read-time">{Math.max(1, Math.round((entry.body ?? '').split(/\s+/).length / 220))} min read</span>
          </div>

          {entry.data.topics && entry.data.topics.length > 0 && (
            <div class="note-topics">
              {entry.data.topics.map((t) => <TopicChip label={t} href={`/garden?topic=${t}`} />)}
            </div>
          )}
        </header>

        <div class="prose">
          <Content />
        </div>

        <nav class="note-nav">
          {prevNote && (
            <a href={`/notes/${prevNote.id}`} class="note-nav-link note-nav-prev">
              ← {prevNote.data.title}
            </a>
          )}
          {nextNote && (
            <a href={`/notes/${nextNote.id}`} class="note-nav-link note-nav-next">
              {nextNote.data.title} →
            </a>
          )}
        </nav>
      </article>
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green-accent);
    text-decoration: none;
    margin-bottom: var(--spacing-5);
    transition: color var(--duration-button) ease;
  }

  .back-link:hover {
    color: var(--color-starbucks-green);
  }

  .note-article {
    max-width: 65ch;
    margin-inline: auto;
  }

  .note-header {
    margin-bottom: var(--spacing-6);
  }

  /* Hero only for evergreen notes (DESIGN.md §6); max-width 32rem keeps
     short notes visually tighter than essay hero. */
  .note-art {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: var(--spacing-5);
    max-width: 32rem;
  }

  .note-art :global(svg),
  .note-art :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Title in Lora 600 — matches essay detail (DESIGN.md §1) */
  .note-title {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.2;
    margin-bottom: var(--spacing-3);
  }

  .note-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    margin-bottom: var(--spacing-3);
    font-size: var(--text-small);
    color: var(--color-text-black-soft);
  }

  .note-divider { opacity: 0.5; }

  .note-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
  }

  .note-nav {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-top: var(--spacing-7);
    padding-top: var(--spacing-5);
    border-top: 1px solid var(--color-hairline);
  }

  .note-nav-link {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green-accent);
    text-decoration: none;
    transition: color var(--duration-button) ease;
  }

  .note-nav-link:hover {
    color: var(--color-starbucks-green);
  }

  .note-nav-next {
    margin-left: auto;
  }

  /* Notes are shorter — slightly tighter body line-height than the shared
     `.prose` utility's 1.7. Scoped to .note-article so other prose pages
     are unaffected. */
  .note-article .prose {
    line-height: 1.65;
  }
</style>