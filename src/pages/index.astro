---
/**
 * Home — `/` (DESIGN.md §4 — identity page).
 * Hero + curated picks + four recent strips (Essays / Notes / Patterns /
 * Library) + dark-near-black Newsletter closing band.
 * Cite: DESIGN.md §4 (home).
 */
import Layout from '@/layouts/Layout.astro';
import GardenCard from '@/components/GardenCard.astro';
import CollectionGrid from '@/components/CollectionGrid.astro';
import Button from '@/components/Button.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import CuratedPicks from '@/components/CuratedPicks.astro';
import NewsletterBand from '@/components/NewsletterBand.astro';
import BookTile from '@/components/BookTile.astro';
import { getCollection } from 'astro:content';

const allEssays = await getCollection('essays');
const allNotes = await getCollection('notes');
const allPatterns = await getCollection('patterns');
const allBooks = await getCollection('books');

const recentEssays = allEssays
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentNotes = allNotes
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentPatterns = allPatterns
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentBooks = allBooks
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0))
  .slice(0, 6);

const curatedPicks = [
  { title: 'On Typography, and the Trust It Quietly Asks For', href: '/essays/on-typography-and-trust' },
  { title: 'Design Systems Are Grammar, Not Paint', href: '/essays/design-systems-are-grammar' },
  { title: 'Token-as-Grammar', href: '/patterns/token-as-grammar' },
];
---

<Layout title="phurix" description="Personal website of Phuriwaj Ruengnaowaroj">
  <section class="hero-section">
    <div class="container-phx hero-grid">
      <div class="hero-content">
        <p class="hero-eyebrow">Phuriwaj Ruengnaowaroj</p>
        <h1 class="hero-headline">
          Writing about web craft, design systems, and the occasional rabbit hole.
        </h1>
        <p class="hero-lede">
          A developer and designer thinking out loud about how interfaces
          communicate — from component APIs to the grammar hiding in our
          design tokens. Based in Bangkok, working on tooling for design
          systems at scale.
        </p>
        <div class="hero-actions">
          <Button variant="primary" href="/garden">Open the Garden</Button>
          <Button variant="outline" href="/essays">Read the latest essay</Button>
        </div>
        <p class="hero-trust">Built with — Astro, Tailwind, MDX, Space Grotesk, Inter, JetBrains Mono</p>
      </div>
      <div class="hero-art">
        <TopicPhoto topic="design" scale="lg" showCredit={true} />
      </div>
    </div>
  </section>

  <section class="container-phx curated-section section">
    <CuratedPicks items={curatedPicks} />
  </section>

  <section class="section-preview container-phx section">
    <div class="preview-header">
      <h2>Essays</h2>
      <Button variant="outline" href="/essays">All essays →</Button>
    </div>
    <CollectionGrid cols={3} gap="md">
      {recentEssays.map((essay) => (
        <GardenCard
          title={essay.data.title}
          type="essay"
          lede={essay.data.lede}
          date={essay.data.date}
          topics={essay.data.topics}
          href={`/essays/${essay.id}`}
        />
      ))}
    </CollectionGrid>
  </section>

  <section class="section-preview container-phx section">
    <div class="preview-header">
      <h2>Notes</h2>
      <Button variant="outline" href="/notes">All notes →</Button>
    </div>
    <CollectionGrid cols={3} gap="md">
      {recentNotes.map((note) => (
        <GardenCard
          title={note.data.title}
          type="note"
          excerpt={note.data.excerpt}
          date={note.data.date}
          topics={note.data.topics}
          growthStage={note.data.growthStage}
          href={`/notes/${note.id}`}
        />
      ))}
    </CollectionGrid>
  </section>

  <section class="section-preview container-phx section">
    <div class="preview-header">
      <h2>Patterns</h2>
      <Button variant="outline" href="/patterns">All patterns →</Button>
    </div>
    <CollectionGrid cols={3} gap="md">
      {recentPatterns.map((pattern) => (
        <GardenCard
          title={pattern.data.title}
          type="pattern"
          excerpt={pattern.data.lede}
          date={pattern.data.date}
          topics={pattern.data.topics}
          href={`/patterns/${pattern.id}`}
        />
      ))}
    </CollectionGrid>
  </section>

  <section class="section-preview container-phx section">
    <div class="preview-header">
      <h2>Library</h2>
      <Button variant="outline" href="/library">Browse the library →</Button>
    </div>
    <div class="library-strip">
      {recentBooks.map((book) => (
        <BookTile
          title={book.data.title}
          author={book.data.author}
          coverColor={book.data.coverColor}
          year={book.data.year}
        />
      ))}
    </div>
  </section>

  <section class="newsletter-closing">
    <div class="container-phx">
      <NewsletterBand />
    </div>
  </section>
</Layout>

<style>
  /* Hero — full-bleed pale-blue wash, 2-col grid on desktop */
  .hero-section {
    padding-block: var(--spacing-15) var(--spacing-12);
    background: var(--color-pale-blue-wash);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-15);
    }
  }

  .hero-content { min-width: 0; }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral-text);
    font-weight: 500;
    margin-bottom: var(--spacing-5);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(4rem, 7vw, 6rem);
    font-weight: 400;
    color: var(--color-heading);
    line-height: 1.05;
    letter-spacing: var(--tracking-display-tight);
    margin-bottom: var(--spacing-7);
    max-width: 22ch;
  }

  .hero-lede {
    font-family: var(--font-sans);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-ink);
    max-width: 60ch;
    margin-bottom: var(--spacing-8);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-5);
    margin-bottom: var(--spacing-8);
  }

  .hero-trust {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted-slate);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    margin: 0;
  }

  .hero-art {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-soft-stone);
  }

  .hero-art :global(svg),
  .hero-art :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 1023px) {
    .hero-art { order: -1; }
  }

  /* Curated picks strip — hairline above, no heading per brief */
  .curated-section {
    border-top: 1px solid var(--color-hairline);
  }

  /* Section preview strips — single-column rhythm, hairline-separated */
  .section-preview {
    border-top: 1px solid var(--color-hairline);
  }

  .preview-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--spacing-8);
    gap: var(--spacing-5);
  }

  /* Library strip — 6-on-desktop / 2-on-mobile grid */
  .library-strip {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-7);
  }

  @media (min-width: 640px) {
    .library-strip { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .library-strip {
      grid-template-columns: repeat(6, 1fr);
      gap: var(--spacing-5);
    }
  }

  /* Newsletter closing band — full-width near-black wrapper */
  .newsletter-closing {
    background: var(--color-near-black);
    color: var(--color-on-dark);
    padding-block: var(--spacing-15);
    margin-block-start: var(--spacing-15);
  }
</style>
