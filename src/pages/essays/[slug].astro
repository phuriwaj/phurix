---
/**
 * Essay detail — `/essays/[slug]` (DESIGN.md §4 — read the essay).
 * Lora 18px body via shared `.prose` utility (src/styles/global.css).
 * Title in Lora 600; back-link + meta row + topic chips as links.
 * Cite: DESIGN.md §4 (essays detail) + DESIGN.md §1 (typography stack).
 */
import Layout from '@/layouts/Layout.astro';
import TopicChip from '@/components/TopicChip.astro';
import TopicPhoto from '@/components/TopicPhoto.astro';
import { getCollection, render } from 'astro:content';
import { pickArtTopic } from '@/lib/topics';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allEssays = await getCollection('essays');
const sortedEssays = allEssays.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const currentIndex = sortedEssays.findIndex((e) => e.id === entry.id);
const prevEssay = currentIndex < sortedEssays.length - 1 ? sortedEssays[currentIndex + 1] : null;
const nextEssay = currentIndex > 0 ? sortedEssays[currentIndex - 1] : null;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(entry.data.date));

const artTopic = pickArtTopic(entry.data.topics);
---

<Layout title={`${entry.data.title} — phurix`} description={entry.data.lede} hideFrap>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: entry.data.title,
      datePublished: entry.data.date.toISOString(),
      description: entry.data.lede,
      keywords: entry.data.topics.join(', '),
      mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
    })}
  />
  <section class="section">
    <div class="container-phx">
      <a href="/essays" class="back-link">← Essays</a>

      <article class="essay-article">
        <header class="essay-header">
          <div class="essay-art">
            <TopicPhoto topic={artTopic} scale="lg" showCredit={true} />
          </div>

          <h1 class="essay-title">{entry.data.title}</h1>

          {entry.data.lede && <p class="essay-lede">{entry.data.lede}</p>}

          <div class="essay-meta">
            <time class="essay-date" datetime={entry.data.date.toISOString()}>
              {formattedDate}
            </time>
            <span class="essay-divider">·</span>
            <span class="essay-read-time">{Math.max(1, Math.round((entry.body ?? '').split(/\s+/).length / 220))} min read</span>
          </div>

          {entry.data.topics && entry.data.topics.length > 0 && (
            <div class="essay-topics">
              {entry.data.topics.map((t) => <TopicChip label={t} href={`/garden?topic=${t}`} />)}
            </div>
          )}
        </header>

        <div class="prose">
          <Content />
        </div>

        <nav class="essay-nav">
          {prevEssay && (
            <a href={`/essays/${prevEssay.id}`} class="essay-nav-link essay-nav-prev">
              ← {prevEssay.data.title}
            </a>
          )}
          {nextEssay && (
            <a href={`/essays/${nextEssay.id}`} class="essay-nav-link essay-nav-next">
              {nextEssay.data.title} →
            </a>
          )}
        </nav>
      </article>
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green-accent);
    text-decoration: none;
    margin-bottom: var(--spacing-5);
    transition: color var(--duration-button) ease;
  }

  .back-link:hover {
    color: var(--color-starbucks-green);
  }

  .essay-article {
    max-width: 65ch;
    margin-inline: auto;
  }

  .essay-header {
    margin-bottom: var(--spacing-6);
  }

  /* Hero fills the 65ch column (DESIGN.md §6) */
  .essay-art {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: var(--spacing-5);
  }

  .essay-art :global(svg),
  .essay-art :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Title in Lora 600 — the prose-page h1 (DESIGN.md §1) */
  .essay-title {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.2;
    margin-bottom: var(--spacing-3);
  }

  .essay-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    color: var(--color-text-black-soft);
    line-height: 1.65;
    margin-bottom: var(--spacing-4);
    font-style: italic;
  }

  .essay-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    margin-bottom: var(--spacing-3);
    font-size: var(--text-small);
    color: var(--color-text-black-soft);
  }

  .essay-divider { opacity: 0.5; }

  .essay-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
  }

  .essay-nav {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-top: var(--spacing-7);
    padding-top: var(--spacing-5);
    border-top: 1px solid var(--color-hairline);
  }

  .essay-nav-link {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green-accent);
    text-decoration: none;
    transition: color var(--duration-button) ease;
  }

  .essay-nav-link:hover {
    color: var(--color-starbucks-green);
  }

  .essay-nav-next {
    margin-left: auto;
  }

  /* .prose shared utility lives in src/styles/global.css (DESIGN.md §1). */
</style>