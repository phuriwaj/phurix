---
/**
 * /projects — A short shelf of side projects.
 * Cite as: DESIGN.md §4 (/projects) — not in top nav; accessible via /about and footer.
 */
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/Card.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="Projects — phurix" description="Projects by phurix">
  <section class="container-phx section">
    <p class="section-eyebrow">Projects</p>
    <h1 class="page-title">Projects</h1>
    <p class="page-lede">
      A small selection of recent projects — case studies available on
      request.
    </p>

    <div class="project-grid mt-7">
      {projects.map((p) => (
        <Card emphasis="lifted">
          <h2 class="project-title">{p.data.title}</h2>
          <p class="project-desc">{p.data.desc}</p>
          <div class="tag-row">
            {p.data.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          {p.data.url && (
            <div class="project-cta">
              <a
                href={p.data.url}
                class="project-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                View project →
              </a>
            </div>
          )}
        </Card>
      ))}
    </div>

    <p class="projects-more">
      More on <a
        href="https://github.com/phurix"
        target="_blank"
        rel="noopener noreferrer"
      >github.com/phurix</a>.
    </p>
  </section>
</Layout>

<style>
  .section-eyebrow {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    font-weight: 600;
    margin-bottom: var(--spacing-2);
  }

  .page-title {
    font-size: clamp(3.6rem, 6vw + 1rem, 4.5rem);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.1;
    margin-bottom: var(--spacing-4);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    max-width: 60ch;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  @media (min-width: 768px) {
    .project-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .project-title {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-starbucks-green);
    margin-bottom: var(--spacing-2);
  }

  .project-desc {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-text-black-soft);
    line-height: 1.6;
    margin-bottom: var(--spacing-3);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
    margin-bottom: var(--spacing-4);
  }

  .tag {
    font-family: var(--font-sans);
    font-size: var(--text-micro);
    font-weight: 600;
    color: var(--color-starbucks-green);
    background: var(--color-green-light);
    padding: 4px 10px;
    border-radius: var(--radius-button);
    letter-spacing: var(--tracking-tight);
  }

  .project-cta {
    margin-top: auto;
  }

  .project-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green-accent);
    background: transparent;
    border: 1px solid var(--color-green-accent);
    padding: 7px 16px;
    border-radius: var(--radius-button);
    text-decoration: none;
    transition:
      color var(--duration-button) ease,
      background-color var(--duration-button) ease;
  }

  .project-link:hover {
    color: var(--color-white);
    background: var(--color-green-accent);
  }

  .projects-more {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-text-black-soft);
    margin-block-start: var(--spacing-6);
  }

  .projects-more a {
    color: var(--color-green-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-button) ease;
  }

  .projects-more a:hover {
    color: var(--color-starbucks-green);
  }

  .mt-7 { margin-top: var(--spacing-7); }
</style>