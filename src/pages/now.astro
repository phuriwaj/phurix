---
/**
 * /now — What the author is up to this month.
 * Cite as: DESIGN.md §4 (/now) — single ordered list, hairline dividers.
 * No announcement bar (deep-focus surface).
 */
import Layout from '@/layouts/Layout.astro';
import { nowItems, lastUpdated } from '@/data/now';

const lastUpdatedDate = new Date(lastUpdated);
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(lastUpdatedDate);
---

<Layout title="Now — phurix" description="What Phuriwaj is up to right now." hideAnnouncement>
  <section class="page-header-section">
    <div class="container-phx">
      <p class="section-eyebrow">Now</p>
      <h1 class="page-title">What I'm up to</h1>
      <p class="page-lede">
        A snapshot of life right now — location, work, reading, and thoughts in
        progress. Updated occasionally, not on a schedule.
      </p>
      <p class="now-last-updated">
        Updated <time datetime={lastUpdatedDate.toISOString()}>{formattedDate}</time>
      </p>
    </div>
  </section>

  <section class="container-phx section now-sections">
    <dl class="now-list">
      {nowItems.map((item) => (
        <div class="now-item">
          <dt class="now-label">{item.label}</dt>
          <dd class="now-value">
            {'value' in item ? (
              <p>{item.value}</p>
            ) : (
              <ul class="reading-list">
                {item.list.map((entry) => (
                  <li>{entry}</li>
                ))}
              </ul>
            )}
          </dd>
        </div>
      ))}
    </dl>
  </section>
</Layout>

<style>
  .page-header-section {
    padding-block: var(--spacing-15) var(--spacing-10);
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral);
    font-weight: 500;
    margin-bottom: var(--spacing-4);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 6vw, 4.8rem);
    font-weight: 400;
    color: var(--color-cohere-black);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    margin-bottom: var(--spacing-5);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-muted-slate);
    max-width: 60ch;
  }

  .now-last-updated {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted-slate);
    margin-block-start: var(--spacing-4);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
  }

  .now-sections {
    padding-block: var(--spacing-12);
  }

  .now-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 65ch;
  }

  .now-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    padding-block: var(--spacing-8);
    border-bottom: 1px solid var(--color-hairline);
  }

  .now-item:first-child {
    border-top: 1px solid var(--color-hairline);
  }

  .now-label {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    font-weight: 500;
    color: var(--color-coral);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    margin: 0;
  }

  .now-value {
    margin: 0;
  }

  .now-value p {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--color-ink);
    margin: 0;
  }

  .reading-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .reading-list li {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-ink);
    line-height: 1.5;
  }

  .reading-list li::before {
    content: '— ';
    color: var(--color-muted-slate);
  }
</style>
