---
/**
 * /now — What the author is up to this month.
 * Cite as: DESIGN.md §4 (/now) — single ordered list, hairline dividers, Lora values.
 * Frap suppressed via `hideFrap` per the deep-focus surface rule.
 */
import Layout from '@/layouts/Layout.astro';

type NowItem =
  | { label: string; value: string }
  | { label: string; list: string[] };

const nowItems: NowItem[] = [
  {
    label: 'Location',
    value: 'Bangkok, Thailand.',
  },
  {
    label: 'Working on',
    value:
      'A design system for a client; a long essay on typography hierarchy; exploring edge-rendering patterns more seriously.',
  },
  {
    label: 'Reading',
    list: [
      'The Design of Everyday Things — Don Norman.',
      'Staff Engineer — Will Larson.',
      'Thinking in Systems — Donella Meadows.',
    ],
  },
  {
    label: 'Thinking about',
    value:
      'The gap between component-level design and system-level design. How context windows change the way we prompt AI tools.',
  },
  {
    label: 'Writing',
    value:
      'Two essays in progress: one on typography hierarchy, one on the anthropology of code review.',
  },
];

const lastUpdated = '2026-07-04';
const lastUpdatedDate = new Date(lastUpdated);
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(lastUpdatedDate);
---

<Layout title="Now — phurix" description="What Phuriwaj is up to right now." hideFrap>
  <section class="container-phx section">
    <p class="section-eyebrow">Now</p>
    <h1 class="page-title">What I'm up to</h1>
    <p class="page-lede">
      A snapshot of life right now — location, work, reading, and thoughts in
      progress. Updated occasionally, not on a schedule.
    </p>
    <p class="now-last-updated">
      Last updated <time datetime={lastUpdatedDate.toISOString()}>{formattedDate}</time>
    </p>
  </section>

  <section class="container-phx section now-sections">
    <dl class="now-list">
      {nowItems.map((item) => (
        <div class="now-item">
          <dt class="now-label">{item.label}</dt>
          <dd class="now-value">
            {'value' in item ? (
              <p>{item.value}</p>
            ) : (
              <ul class="reading-list">
                {item.list.map((entry) => (
                  <li>{entry}</li>
                ))}
              </ul>
            )}
          </dd>
        </div>
      ))}
    </dl>
  </section>
</Layout>

<style>
  .section-eyebrow {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    color: var(--color-starbucks-green);
    font-weight: 600;
    margin-bottom: var(--spacing-2);
  }

  .page-title {
    font-size: clamp(3.6rem, 6vw + 1rem, 4.5rem);
    font-weight: 600;
    color: var(--color-starbucks-green);
    line-height: 1.1;
    margin-bottom: var(--spacing-4);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-black-soft);
    max-width: 60ch;
  }

  .now-last-updated {
    font-family: var(--font-sans);
    font-size: var(--text-micro);
    color: var(--color-text-black-soft);
    margin-block-start: var(--spacing-2);
  }

  .now-sections {
    padding-block: var(--spacing-6);
  }

  .now-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 65ch;
  }

  .now-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    padding-block: var(--spacing-5);
    border-bottom: 1px solid var(--color-hairline);
  }

  .now-item:first-child {
    border-top: 1px solid var(--color-hairline);
  }

  .now-label {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-starbucks-green);
    text-transform: uppercase;
    letter-spacing: var(--tracking-loose);
    margin: 0;
  }

  .now-value {
    margin: 0;
  }

  .now-value p {
    font-family: var(--font-serif);
    font-size: var(--text-prose);
    line-height: 1.65;
    color: var(--color-text-black);
    margin: 0;
  }

  .reading-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .reading-list li {
    font-family: var(--font-serif);
    font-size: var(--text-prose);
    color: var(--color-text-black);
    line-height: 1.65;
  }

  .reading-list li::before {
    content: '— ';
    color: var(--color-text-black-soft);
  }
</style>