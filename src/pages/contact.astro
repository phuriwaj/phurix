---
/**
 * /contact — Three channels and one direct action.
 * Cite as: DESIGN.md §4 (/contact) — email-first per Sloan / Mod.
 */
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';

const channels = [
  { label: 'Email', value: 'hello@phurix.dev', href: 'mailto:hello@phurix.dev' },
  { label: 'GitHub', value: '@phurix', href: 'https://github.com/phurix' },
  { label: 'Mastodon', value: '@phurix@hachyderm.io', href: 'https://hachyderm.io/@phurix' },
];
---

<Layout title="Contact — phurix" description="Get in touch with phurix">
  <section class="page-header-section">
    <div class="container-phx">
      <p class="section-eyebrow">Contact</p>
      <h1 class="page-title">Get in touch.</h1>
      <p class="page-lede">
        Three channels below — pick whichever fits. Email is best for anything
        that needs a back-and-forth.
      </p>
    </div>
  </section>

  <section class="container-phx section">
    <div class="contact-grid">
      {channels.map((c) => (
        <Card emphasis="bordered">
          <p class="channel-label">{c.label}</p>
          <a href={c.href} class="channel-value">{c.value}</a>
        </Card>
      ))}
    </div>

    <div class="cta-row mt-15">
      <Button variant="primary" href="mailto:hello@phurix.dev">
        Email me directly
      </Button>
    </div>
  </section>
</Layout>

<style>
  .page-header-section {
    padding-block: var(--spacing-15) var(--spacing-10);
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral);
    font-weight: 500;
    margin-bottom: var(--spacing-4);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 6vw, 4.8rem);
    font-weight: 400;
    color: var(--color-cohere-black);
    line-height: 1.1;
    letter-spacing: var(--tracking-display-tight);
    margin-bottom: var(--spacing-5);
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-muted-slate);
    max-width: 60ch;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-5);
  }

  @media (min-width: 768px) {
    .contact-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .channel-label {
    font-family: var(--font-mono);
    font-size: var(--text-mono-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-coral);
    font-weight: 500;
    margin: 0 0 var(--spacing-4);
  }

  .channel-value {
    font-family: var(--font-display);
    font-size: var(--text-feature-heading);
    font-weight: 400;
    color: var(--color-ink);
    word-break: break-all;
    text-decoration: none;
    letter-spacing: var(--tracking-display-tight);
  }

  .channel-value:hover { color: var(--color-action-blue); }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-5);
  }

  .mt-15 { margin-top: var(--spacing-15); }
</style>
